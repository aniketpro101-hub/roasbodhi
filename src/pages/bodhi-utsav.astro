  </main>

  <!-- Minimal Footer -->
  <footer class="bg-neutral-dark text-white/50 text-center py-6 select-none border-t border-white/5 text-xs font-body">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span>© {new Date().getFullYear()} RoasBodhi™ Digital Pvt. Ltd. All rights reserved.</span>
      <span>Made with 🔱 in Aamchi Mumbai, India</span>
    </div>
  </footer>

