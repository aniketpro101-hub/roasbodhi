<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Countdown Timer Logic
    const countdownEl = document.getElementById('countdown');
    if (countdownEl) {
      const OFFER_END_DATE = new Date('2026-10-31T23:59:59+05:30');
      
      const updateTimer = () => {
        const now = new Date().getTime();
        const distance = OFFER_END_DATE.getTime() - now;

        if (distance <= 0) {
          countdownEl.textContent = "Offer Extended - Contact for Special Pricing";
          countdownEl.className = "font-mono text-sm bg-emerald-600/30 text-white px-2.5 py-1 rounded";
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const format = (num: number) => num < 10 ? `0${num}` : num;
        
        countdownEl.textContent = `${days}d : ${format(hours)}h : ${format(minutes)}m : ${format(seconds)}s`;

        // Apply styles based on urgency
        if (distance < 1000 * 60 * 60) {
          // Last hour: Pulsing red
          countdownEl.className = "font-mono text-sm bg-red-600 text-white px-2.5 py-1 rounded animate-pulse font-bold";
        } else if (distance < 1000 * 60 * 60 * 24) {
          // Under 24 hours: Red background
          countdownEl.className = "font-mono text-sm bg-red-500/80 text-white px-2.5 py-1 rounded font-bold";
        } else {
          // Normal state
          countdownEl.className = "font-mono text-sm bg-black/15 text-white px-2.5 py-1 rounded";
        }
      };

      updateTimer();
      setInterval(updateTimer, 1000);
    }

    // 2. Offer Swapping Switcher Tab Logic
    const switcherButtons = document.querySelectorAll('#utsav-switcher button');
    const panelWeb = document.getElementById('panel-web')!;
    const panelAds = document.getElementById('panel-ads')!;
    const utsavTitle = document.getElementById('utsav-title')!;

    switcherButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        switcherButtons.forEach(b => {
          b.classList.remove('bg-white', 'text-neutral-dark', 'shadow-sm', 'active-tab');
          b.classList.add('text-neutral-stone');
        });

        btn.classList.remove('text-neutral-stone');
        btn.classList.add('bg-white', 'text-neutral-dark', 'shadow-sm', 'active-tab');

        const activeTarget = btn.getAttribute('data-target')!;
        const dataEl = document.getElementById('utsav-data');
        const webPrice = parseInt(dataEl.dataset.webPrice).toLocaleString('en-IN');
        const webWorth = parseInt(dataEl.dataset.webWorth).toLocaleString('en-IN');
        const adsPrice = parseInt(dataEl.dataset.adsPrice).toLocaleString('en-IN');

        if (activeTarget === 'web') {
          panelAds.classList.add('opacity-0', 'scale-95');
          setTimeout(() => {
            panelAds.classList.add('hidden');
            panelWeb.classList.remove('hidden');
            setTimeout(() => {
              panelWeb.classList.remove('opacity-0', 'scale-95');
              panelWeb.classList.add('opacity-100', 'scale-100');
            }, 10);
          }, 300);
          
          utsavTitle.innerHTML = `Get a ₹${webWorth} Website <br /><span class="bg-gradient-to-r from-primary-saffron to-primary-gold bg-clip-text text-transparent">For Just ₹${webPrice}</span>`;
        } else {
          panelWeb.classList.add('opacity-0', 'scale-95');
          setTimeout(() => {
            panelWeb.classList.add('hidden');
            panelAds.classList.remove('hidden');
            setTimeout(() => {
              panelAds.classList.remove('opacity-0', 'scale-95');
              panelAds.classList.add('opacity-100', 'scale-100');
            }, 10);
          }, 300);

          utsavTitle.innerHTML = `Manage ALL Your Ads <br /><span class="bg-gradient-to-r from-primary-saffron to-primary-gold bg-clip-text text-transparent">For Just ₹${adsPrice}/mo</span>`;
        }
      });
    });

    // 3. UTM Parameter Capture and Insertion
    const urlParams = new URLSearchParams(window.location.search);
    const utmSource = urlParams.get('utm_source') || 'website';
    const utmMedium = urlParams.get('utm_medium') || 'form';
    const utmCampaign = urlParams.get('utm_campaign') || 'utsav_page';

    const sourceInput = document.getElementById('utm_source');
    const mediumInput = document.getElementById('utm_medium');
    const campaignInput = document.getElementById('utm_campaign');

    if (sourceInput) sourceInput.value = utmSource;
    if (mediumInput) mediumInput.value = utmMedium;
    if (campaignInput) campaignInput.value = utmCampaign;

    // 4. WhatsApp Direct Click Tracking
    const waLink = document.getElementById('utsav-whatsapp-direct-link');
    if (waLink) {
      waLink.addEventListener('click', () => {
        if (window.gtag) {
          window.gtag('event', 'whatsapp_click', { button_location: 'utsav_page' });
        }
      });
    }

    // 5. Client side Validation & AJAX Submission
    const form = document.getElementById('utsav-claim-form') as HTMLFormElement;
    if (form) {
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const submitBtnSpan = submitBtn.querySelector('span')!;

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        // Basic validation checks
        const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
        const phone = (form.elements.namedItem('phone') as HTMLInputElement).value.trim();
        const city = (form.elements.namedItem('city') as HTMLInputElement).value.trim();
        const businessType = (form.elements.namedItem('business_type') as HTMLSelectElement).value;
        const offerType = form.querySelector('input[name="offer_type"]:checked') as HTMLInputElement;

        if (!name || !phone || !city || !businessType || !offerType) {
          window.showToast("Please fill in all required fields.", "error");
          return;
        }

        // Phone check (10 to 15 digits)
        const phoneRegex = /^\+?[0-9\s-]{10,15}$/;
        if (!phoneRegex.test(phone.replace(/\+/g, ''))) {
          window.showToast("Please enter a valid 10-15 digit phone number.", "error");
          return;
        }

        // Honeypot check
        const botcheck = form.elements.namedItem('botcheck') as HTMLInputElement;
        if (botcheck && botcheck.checked) {
          console.warn("Spam detected");
          return;
        }

        // Load State (Disable button and show status text)
        submitBtn.disabled = true;
        const origText = submitBtnSpan.textContent;
        submitBtnSpan.textContent = "Reserving Spot...";

        const formData = new FormData(form);

        fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        })
        .then(async (response) => {
          const json = await response.json();
          if (response.status === 200) {
            // GA4 event
            if (window.gtag) {
              window.gtag('event', 'form_submit', {
                form_location: 'utsav_page',
                utm_source: utmSource,
                utm_medium: utmMedium,
                utm_campaign: utmCampaign
              });
            }
            window.showToast("Spot reserved successfully! Redirecting...", "success");
            setTimeout(() => {
              window.location.href = '/thank-you/';
            }, 1500);
          } else {
            if (window.gtag) {
              window.gtag('event', 'form_error', { form_location: 'utsav_page', error_message: json.message || 'unknown_error' });
            }
            window.showToast(json.message || "Reservation failed. Please check access key.", "error");
            submitBtn.disabled = false;
            submitBtnSpan.textContent = origText;
          }
        })
        .catch((err) => {
          if (window.gtag) {
            window.gtag('event', 'form_error', { form_location: 'utsav_page', error_message: 'network_failure' });
          }
          window.showToast("Network failure. Please claim spot via WhatsApp instead.", "error");
          submitBtn.disabled = false;
          submitBtnSpan.textContent = origText;
        });
      });
    }
  });
</script>

