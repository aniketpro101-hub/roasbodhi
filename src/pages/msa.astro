---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Master Service Agreement Template | RoasBodhi";
const pageDescription = "Standard Master Service Agreement (MSA) template for Namaste Sales Enterprises (operating as RoasBodhi™) in compliance with the Indian Contract Act 1872.";
---

<BaseLayout title={pageTitle} description={pageDescription} noIndex={true}>
  
  <Header />

  <main class="flex-grow pt-32 pb-24 bg-neutral-ghost text-neutral-charcoal text-left">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="mb-12 border-b border-neutral-mist pb-8">
        <span class="px-3 py-1 rounded-full bg-primary-saffron/10 text-primary-saffron text-[10px] font-display font-extrabold uppercase tracking-widest">
          Contract Template
        </span>
        <h1 class="font-display font-extrabold text-neutral-dark text-3xl sm:text-5xl mt-3 tracking-tight">
          Master Service Agreement
        </h1>
        <p class="font-body text-xs text-neutral-stone mt-2 font-semibold">
          Standard Client Contract Template | For Digital Signature
        </p>
      </div>

      <div class="prose prose-sm max-w-none font-body text-neutral-charcoal/90 leading-relaxed space-y-8 select-none bg-white p-6 sm:p-10 border border-neutral-mist rounded-3xl shadow-sm">
        
        <div class="text-center font-display font-extrabold text-xl text-neutral-dark tracking-tight mb-8">
          MASTER SERVICE AGREEMENT
        </div>

        <!-- TOP OF AGREEMENT -->
        <div class="space-y-4 border-b border-neutral-mist pb-8 text-xs font-semibold">
          <p>
            **BY AND BETWEEN:**
          </p>
          <p>
            **NAMASTE SALES ENTERPRISES**, a sole proprietorship registered under the laws of India, operating under the brand name **"RoasBodhi"**, having its principal place of business at **501 Shankar Apartment Sec 20 Nerul W Navi Mumbai 400706, Maharashtra, India** (hereinafter referred to as the **"Service Provider"** or the **"Company"**, which expression shall unless repugnant to the context include its successors and permitted assigns);
          </p>
          <p>
            **AND**
          </p>
          <div class="border border-neutral-mist/60 p-4 rounded-xl space-y-2 bg-neutral-ghost/50">
            <p>**Client Legal Name:** ____________________________________________________</p>
            <p>**Trading Name / DBA (if applicable):** ________________________________________</p>
            <p>**Registered Corporate Address:** _____________________________________________</p>
            <p>**GSTIN (if applicable):** ___________________________________________________</p>
            <p>**PAN Number:** ___________________________________________________________</p>
            <p>**Authorized Representative & Designation:** __________________________________</p>
            <p>**Contact Phone / Mobile:** __________________________________________________</p>
            <p>**Official Communication Email:** ______________________________________________</p>
            <p class="text-[10px] text-neutral-stone italic">(Hereinafter referred to as the **"Client"**, which expression shall unless repugnant to the context include its successors and permitted assigns).</p>
          </div>
          <p>
            **Agreement Number:** RB-MSA-__________________ | **Effective Date:** ____ / ____ / 202__
          </p>
        </div>

        <!-- RECITALS -->
        <section class="space-y-3">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            RECITALS
          </h2>
          <p class="text-xs">
            **WHEREAS**, the Company is engaged in providing professional digital marketing agency services, including website development, Google My Business optimizations, search advertisements, and social media marketing; and
          </p>
          <p class="text-xs">
            **WHEREAS**, the Client desires to engage the Company to perform certain marketing, consulting, and development services as detailed herein; and
          </p>
          <p class="text-xs">
            **NOW, THEREFORE**, in consideration of the mutual covenants, promises, and conditions set forth in this Agreement, both parties agree to all clauses below.
          </p>
        </section>

        <!-- AGREEMENT SECTIONS -->
        <!-- SECTION 1 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            1. DEFINITIONS AND KEY TERMS
          </h2>
          <p class="text-xs">
            In this Agreement, the following terms shall be defined as:
          </p>
          <ul class="list-disc pl-6 space-y-1.5 text-[11px]">
            <li>**"SOW" (Scope of Work):** A written document or schedule detailing the specific services, pricing, milestones, and deliverables agreed for a project.</li>
            <li>**"Deliverables":** The final customized website files, graphic creatives, and setup metrics generated by us for you.</li>
            <li>**"Ad Spend":** The actual budget paid directly by the Client to advertising networks (such as Meta Ads or Google Ads). This is separate from our management fees.</li>
            <li>**"Management Fee":** Our monthly service charge for campaign optimization, management, and tracking.</li>
            <li>**"Aseem Revisions":** Our proprietary structured revision cycles, as detailed in Section 8.</li>
          </ul>
        </section>

        <!-- SECTION 2 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            2. SERVICES AND SCOPE OF WORK
          </h2>
          <p class="text-xs">
            The Client engages the Company to perform services in accordance with the selections below:
          </p>
          <div class="border border-neutral-mist/60 p-4 rounded-xl space-y-2.5 text-xs bg-neutral-ghost/30">
            <label class="flex items-center gap-2">
              <input type="checkbox" disabled />
              <span>**Web Design & Development** (Plan: [ ] Ankur | [ ] Vriddhi | [ ] Siddhi)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" disabled />
              <span>**Meta Ads Management** (Plan: [ ] Jyoti | [ ] Agni | [ ] Pralaya)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" disabled />
              <span>**Google Ads Management** (Plan: [ ] Disha | [ ] Chakra | [ ] Vajra)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" disabled />
              <span>**GMB Maps Optimization** (Plan: [ ] Sthapna | [ ] Unnati | [ ] Samrajya)</span>
            </label>
          </div>
          <p class="text-xs">
            All detailed deliverables, milestones, start dates, and deadlines are defined in **Schedule A** and **Schedule C** of this Agreement.
          </p>
        </section>

        <!-- SECTION 3 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            3. FEES AND BILLING TERMS
          </h2>
          
          <div class="space-y-1">
            <h3 class="font-display font-bold text-xs text-neutral-dark">
              3A. Web Design Services (Pay-After-Seeing Model)
            </h3>
            <p class="text-xs">
              We design and host your website preview with **₹0 advance payment**. Upon your written design approval, the full package price of **₹________________** becomes due. All fees must clear before we register custom domains, transfer file directories, or launch the live site.
            </p>
          </div>

          <div class="space-y-1">
            <h3 class="font-display font-bold text-xs text-neutral-dark">
              3B. Ad Management Services
            </h3>
            <p class="text-xs">
              Ad management retainer fees are billed **monthly in advance**.
            </p>
            <ul class="list-disc pl-6 space-y-1 text-[11px]">
              <li>**Setup Fee:** A one-time fee of **₹________________** is due upon signing and is non-refundable once campaign planning starts.</li>
              <li>**Monthly Management Fee:** A monthly fee of **₹________________** is due on the 1st of every billing month.</li>
              <li>**Minimum Term:** This agreement requires a **3-month minimum contract** to stabilize campaign performance.</li>
              <li>**Late Payments:** Late payments accrue interest at a rate of **2% per month** from the invoice date. Paused campaigns due to non-payment require a **₹2,000 reactivation fee** to resume.</li>
            </ul>
          </div>
        </section>

        <!-- SECTION 4 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            4. TERM AND TERMINATION
          </h2>
          <p class="text-xs">
            **Term:** The initial term of this SOW is **________________ months**, beginning on the Effective Date. Services will automatically renew monthly unless either party provides written notice of non-renewal at least **15 days** before the next billing cycle.
          </p>
          <p class="text-xs">
            **Termination for Cause:** Either party may terminate this SOW immediately if the other party commits a material breach and fails to cure it within **15 days** of receiving written notice. We reserve the right to suspend or terminate services immediately, without notice, if the Client is found in breach of our Prohibited Industries or Anti-Fraud terms.
          </p>
        </section>

        <!-- SECTION 5 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            5. INTELLECTUAL PROPERTY RIGHTS
          </h2>
          <p class="text-xs">
            **Pre-Existing IP:** Each party retains ownership of their pre-existing intellectual property, templates, and core methodologies.
          </p>
          <p class="text-xs">
            **Ownership Transfer:** Ownership of final website deliverables, design layouts, and custom code transfers to the Client **only after all invoices are paid in full**. Until payment is cleared, the copyright of all source code, assets, and layouts remains with us.
          </p>
          <p class="text-xs">
            **Portfolio Rights:** The Company retains the right to display project deliverables, case studies, and Client branding in our portfolio and promotional materials.
          </p>
        </section>

        <!-- SECTION 6 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            6. REVISION POLICY ("ASEEM" REVISIONS)
          </h2>
          <p class="text-xs">
            To maintain project timelines, revisions are structured in rounds:
          </p>
          <ul class="list-disc pl-6 space-y-1 text-[11px]">
            <li>**Ankur Plan:** Up to **5 revision rounds**.</li>
            <li>**Vriddhi Plan:** Up to **8 revision rounds**.</li>
            <li>**Siddhi Plan:** Up to **12 revision rounds**.</li>
            <li>**Definition of a Round:** A single revision round consists of the Client submitting **one consolidated list** of adjustments. Submitting edits across multiple separate emails will be counted as separate rounds. All requested changes must fit within the scope defined at onboarding. Complete layout redesigns after draft approval require a new quote.</li>
          </ul>
        </section>

        <!-- SECTION 7 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            7. NO GUARANTEE OF RESULTS
          </h2>
          <p class="text-xs">
            The Company optimizes campaigns and website designs to the best of its professional ability. However, we **do not guarantee specific business outcomes, search rankings, leads, sales, or ROAS multipliers**. Results depend on external variables, product demand, your pricing, competitor activity, and your sales team's lead follow-up times.
          </p>
        </section>

        <!-- SECTION 8 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            8. PLATFORM ACCESS AND POLICIES
          </h2>
          <p class="text-xs">
            The Client agrees to grant us appropriate partner or admin access to their Meta Business Manager, Google Ads accounts, and Google Business Profile. We are not responsible for account bans or restrictions.
          </p>
        </section>

        <!-- SECTION 9 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            9. LIMITATION OF LIABILITY
          </h2>
          <p class="text-xs">
            To the maximum extent permitted by law, Namaste Sales Enterprises, its directors, and employees shall not be liable for any indirect, special, incidental, or consequential damages (including loss of profits, revenue, or business opportunities) arising out of your use or inability to use our services.
          </p>
          <p class="text-xs font-bold">
            **Liability Cap:** In no event shall our total cumulative liability exceed the **total Management Fee actually paid by the Client to us during the three (3) months** immediately preceding the event that gave rise to the claim.
          </p>
        </section>

        <!-- SECTION 10 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            10. CONFIDENTIALITY
          </h2>
          <p class="text-xs">
            Both parties agree to treat all business plans, access details, pricing formulas, and customer records shared during the engagement as confidential. Neither party shall disclose this information to any third party without written consent, except when required by law. This confidentiality obligation remains in effect for **3 years** following the termination of our services.
          </p>
        </section>

        <!-- SECTION 11 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            11. NON-SOLICITATION
          </h2>
          <p class="text-xs font-semibold">
            During the service period and for **two (2) years** following the termination of services, the Client agrees not to poach, recruit, or hire any of our developers, designers, or strategists. Any breach of this non-solicitation clause will result in an automatic penalty payment to the Company equal to **six (6) months** of the solicited employee's last drawn salary.
          </p>
        </section>

        <!-- SECTION 12 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            12. FORCE MAJEURE
          </h2>
          <p class="text-xs">
            Neither party shall be liable for delays or failures to perform obligations under this Agreement caused by events beyond their reasonable control, including natural disasters, pandemics, government shutdowns, cyber warfare, labor strikes, power grid failures, or third-party platform outages (Meta or Google server down times). If a Force Majeure event persists for more than **60 days**, either party may terminate the contract upon written notice.
          </p>
        </section>

        <!-- SECTION 13 -->
        <section class="space-y-2">
          <h2 class="font-display font-extrabold text-sm sm:text-base text-neutral-dark border-l-3 border-primary-saffron pl-2.5">
            13. DISPUTE RESOLUTION & GOVERNING LAW
          </h2>
          <p class="text-xs">
            This SOW shall be governed by and construed in accordance with the **laws of India**. Any legal action, suit, or proceeding arising under or in connection with this agreement shall be subject to the exclusive jurisdiction of the **courts at Navi Mumbai / Thane, Maharashtra, India**. Both parties agree to resolve disputes through binding arbitration before a single arbitrator appointed by us, held in **Navi Mumbai**.
          </p>
        </section>

        <!-- SCHEDULES -->
        <div class="border-t border-neutral-mist pt-8 space-y-6">
          <div class="text-center font-display font-extrabold text-base text-neutral-dark">
            SCHEDULE A: DETAILED SCOPE OF WORK
          </div>
          <div class="border border-dashed border-neutral-mist p-6 text-center text-xs text-neutral-stone italic rounded-xl">
            [Insert SOW Specific Deliverables, Page counts, Campaign configurations, and Specific Target Parameters here]
          </div>

          <div class="text-center font-display font-extrabold text-base text-neutral-dark">
            SCHEDULE B: FEE SCHEDULE
          </div>
          <div class="border border-dashed border-neutral-mist p-6 text-center text-xs text-neutral-stone italic rounded-xl">
            [Insert Invoice Milestones, Deposit Amounts, GST invoicing schedules, and billing cycles here]
          </div>
        </div>

        <!-- SIGNATURE BLOCK -->
        <div class="border-t border-neutral-mist pt-8 grid grid-cols-1 md:grid-cols-2 gap-8 text-xs">
          
          <div class="space-y-4">
            <p class="font-bold">For NAMASTE SALES ENTERPRISES:</p>
            <div class="h-20 border-b border-neutral-mist w-full"></div>
            <p>Proprietor / Director: ________________________________</p>
            <p>Designation: Proprietor / Director</p>
            <p>Date: ____ / ____ / 202__</p>
          </div>

          <div class="space-y-4">
            <p class="font-bold">For CLIENT:</p>
            <div class="h-20 border-b border-neutral-mist w-full"></div>
            <p>Authorized Representative: ________________________________</p>
            <p>Designation: ________________________________</p>
            <p>Date: ____ / ____ / 202__</p>
          </div>

        </div>

      </div>

    </div>
  </main>

  <Footer />

</BaseLayout>
