  <!-- Script for interactivity (Tabs, Slides, Timer, Modals, Forms) -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. COUNTDOWN TIMER
      const OFFER_END_DATE = new Date('2026-10-31T23:59:59+05:30');
      
      const updateTimer = () => {
        const now = new Date();
        const diff = OFFER_END_DATE.getTime() - now.getTime();
        
        if (diff <= 0) {
          const banner = document.getElementById('utsav-countdown');
          if (banner) banner.innerText = "OFFER EXPIRED - Join Waitlist";
          const timerDiv = document.getElementById('offer-timer');
          if (timerDiv) timerDiv.innerHTML = "<div class='text-sm text-primary-gold'>Celebration Offer Closed - Contact for Next Batch</div>";
          return;
        }
        
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
        const mins = Math.floor((diff / (1000 * 60)) % 60);
        const secs = Math.floor((diff / 1000) % 60);
        
        // Urgency header bar
        const banner = document.getElementById('utsav-countdown');
        if (banner) {
          banner.innerText = `${days}d : ${hours}h : ${mins}m : ${secs}s`;
        }
        
        // Large detail timer
        const tDays = document.getElementById('timer-days');
        const tHours = document.getElementById('timer-hours');
        const tMins = document.getElementById('timer-mins');
        const tSecs = document.getElementById('timer-secs');
        
        if (tDays) tDays.innerText = String(days).padStart(2, '0');
        if (tHours) tHours.innerText = String(hours).padStart(2, '0');
        if (tMins) tMins.innerText = String(mins).padStart(2, '0');
        if (tSecs) tSecs.innerText = String(secs).padStart(2, '0');
      };
      
      setInterval(updateTimer, 1000);
      updateTimer();

      // 2. REPORT DETAILS TABS SWITCHER
      const tabButtons = document.querySelectorAll('#report-tab-switcher .tab-btn');
      const tabPanels = document.querySelectorAll('#report-tab-panels .tab-panel');

      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Deactivate all buttons
          tabButtons.forEach(b => {
            b.classList.remove('bg-white', 'text-primary-indigo', 'shadow-md', 'active');
            b.classList.add('text-white/70');
          });
          
          // Activate clicked button
          btn.classList.add('bg-white', 'text-primary-indigo', 'shadow-md', 'active');
          btn.classList.remove('text-white/70');

          const targetTab = btn.getAttribute('data-tab');

          // Hide all panels
          tabPanels.forEach(panel => {
            panel.classList.add('hidden', 'opacity-0', 'scale-95');
          });

          // Show targeted panel
          const activePanel = document.getElementById(`panel-${targetTab}`);
          if (activePanel) {
            activePanel.classList.remove('hidden');
            setTimeout(() => {
              activePanel.classList.remove('opacity-0', 'scale-95');
            }, 50);
          }
        });
      });

      // 3. SAMPLE REPORT SLIDESHOW
      let currentPage = 1;
      const totalPages = 6;
      
      const prevBtn = document.getElementById('prev-page-btn') as HTMLButtonElement;
      const nextBtn = document.getElementById('next-page-btn') as HTMLButtonElement;
      const indicator = document.getElementById('page-indicator');
      const pages = document.querySelectorAll('#report-pages-container .report-page');

      const updatePages = () => {
        pages.forEach(p => p.classList.add('hidden'));
        const activePage = document.querySelector(`.report-page[data-page="${currentPage}"]`);
        if (activePage) activePage.classList.remove('hidden');

        if (indicator) indicator.innerText = `Page ${currentPage} of ${totalPages}`;

        // Disable buttons
        if (prevBtn) prevBtn.disabled = currentPage === 1;
        if (nextBtn) nextBtn.disabled = currentPage === totalPages;
      };

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          if (currentPage > 1) {
            currentPage--;
            updatePages();
          }
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          if (currentPage < totalPages) {
            currentPage++;
            updatePages();
          }
        });
      }
      updatePages();

      // 4. EMAIL CAPTURE MODAL FOR SAMPLE REPORT
      const downloadBtn = document.getElementById('download-sample-btn');
      const modal = document.getElementById('email-modal');
      const closeModalBtn = document.getElementById('close-modal-btn');
      const sampleForm = document.getElementById('sample-download-form');
      const modalSuccess = document.getElementById('modal-success-msg');

      if (downloadBtn && modal) {
        downloadBtn.addEventListener('click', () => {
          modal.classList.remove('hidden');
          setTimeout(() => {
            modal.classList.remove('opacity-0');
          }, 50);
        });
      }

      const closeModal = () => {
        if (modal) {
          modal.classList.add('opacity-0');
          setTimeout(() => {
            modal.classList.add('hidden');
            // reset form and state
            if (sampleForm) sampleForm.classList.remove('hidden');
            if (modalSuccess) modalSuccess.classList.add('hidden');
          }, 300);
        }
      };

      if (closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
      
      if (modal) {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) closeModal();
        });
      }

      if (sampleForm) {
        sampleForm.addEventListener('submit', (e) => {
          e.preventDefault();
          // Hide form and show success
          sampleForm.classList.add('hidden');
          if (modalSuccess) modalSuccess.classList.remove('hidden');
          // Automatically close modal after 4 seconds
          setTimeout(closeModal, 4000);
        });
      }

      // 5. BOOKING FORM PACKAGE SELECT & PRICE BINDING
      const packageSelect = document.getElementById('package-select') as HTMLSelectElement;
      const priceDisplay = document.getElementById('form-price-display');
      
      const priceMap: Record<string, string> = {
        'drishti-utsav': '₹' + '4,999',
        'chakshu': '₹' + '4,999',
        'divya-drishti': '₹' + '14,999',
        'trikaldarshi': '₹' + '29,999'
      };

      if (packageSelect && priceDisplay) {
        packageSelect.addEventListener('change', () => {
          const val = packageSelect.value;
          priceDisplay.innerText = priceMap[val] || '₹' + '4,999';
        });
      }

      // 6. BOOKING FORM SUBMISSION
      const orderForm = document.getElementById('research-order-form') as HTMLFormElement;
      const bookingSuccess = document.getElementById('booking-success-msg');

      if (orderForm) {
        orderForm.addEventListener('submit', (e) => {
          e.preventDefault();
          orderForm.classList.add('hidden');
          if (bookingSuccess) bookingSuccess.classList.remove('hidden');
        });
      }

    });
  </script>

