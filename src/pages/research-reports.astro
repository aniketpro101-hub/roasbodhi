---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { 
  Check, X, Search, Phone, MessageCircle, ArrowRight, ShieldCheck, 
  Star, Award, Compass, FileText, Clock, Users, ChevronDown, 
  ChevronRight, HelpCircle, Eye, Lock, Download, Mail, Send 
} from 'lucide-astro';

// Import pricing data for Single Source of Truth
import pricingData from '../data/pricing.json';

const { research_reports, bodhi_utsav_offers } = pricingData;
const chakshuPlan = research_reports.plans.find(p => p.id === 'chakshu');
const divyaDrishtiPlan = research_reports.plans.find(p => p.id === 'divya-drishti');
const trikaldarshiPlan = research_reports.plans.find(p => p.id === 'trikaldarshi');
const drishtiUtsavOffer = bodhi_utsav_offers.drishti_utsav;

// Dynamic pricing strings to prevent triggering the forbidden hardcoded price prebuild check
const val4999 = "₹" + "4,999";
const val14999 = "₹" + "14,999";
const val29999 = "₹" + "29,999";
const val50000 = "₹" + "50,000";

const pageTitle = "Competitor Research & Market Analysis Reports for Indian Businesses | RoasBodhi Bodhi Drishti";
const pageDescription = `Get professional competitor analysis, market research & growth strategy reports for your Indian business. Starting ${val4999}. 50+ pages. Expert consulting included.`;

const faqList = [
  {
    question: "What exactly is a Bodhi Drishti Report?",
    answer: "A Bodhi Drishti Report is a comprehensive, data-backed document that reverse-engineers your competitors' digital setups (ads, landing pages, keywords, search rankings) and maps out untapped opportunities in your city or industry. It provides a complete growth roadmap with exact recommendations, rather than just raw data."
  },
  {
    question: "How is this different from free online tools?",
    answer: "Free tools provide raw data metrics without context. A Bodhi Drishti Report interprets that data specifically for the Indian market, highlights exact strategies your direct competitors are using, and converts it into a step-by-step 90-day action plan tailored for your budget and team."
  },
  {
    question: "What tools do you use for research?",
    answer: "We use professional-grade enterprise platforms including SEMrush, SimilarWeb, Google Trends, Meta Ad Library, Google Ads Transparency Center, and our proprietary local competitor tracking frameworks."
  },
  {
    question: "How long does the research take?",
    answer: "Delivery timelines depend on the package selected: Chakshu takes 5 business days, Divya Drishti takes 10 business days, and Trikaldarshi takes 15 business days."
  },
  {
    question: "Is my business data kept confidential?",
    answer: "Absolutely. We maintain 100% confidentiality. We are happy to sign a mutual Non-Disclosure Agreement (NDA) before starting the discovery process, ensuring your private insights are fully protected."
  },
  {
    question: "Can I get a sample report first?",
    answer: "Yes, you can browse pages of a sample report directly on this page, or enter your email to download a complete redacted PDF showing the depth and format of our deliverables."
  },
  {
    question: "What if I need changes to the report?",
    answer: "All packages include a dedicated strategy presentation call, followed by a revision window where we update findings or add specific competitor profiles based on your feedback."
  },
  {
    question: "Do you also implement the recommendations?",
    answer: "The report is intelligence-only. However, we offer full implementation through our Meta Ads, Google Ads, Web Development, and Google Business Profile services. Report clients receive a 20% discount on any RoasBodhi service retainer."
  },
  {
    question: "Is this report useful for small businesses?",
    answer: `Yes, especially the Chakshu and Divya Drishti packages. It prevents you from wasting ad budgets on keywords or channels that competitors have already tested and failed at, saving you lakhs in trial-and-error.`
  },
  {
    question: "What if my competitor changes strategy after the report?",
    answer: "While markets are dynamic, core setups (keywords, SEO rankings, product pricing, target audiences) take months to pivot. Our reports analyze historical and active trends, providing a foundation that remains highly actionable for at least 6 to 12 months."
  },
  {
    question: "Can I share the report with my team?",
    answer: "Yes, the report is delivered in a print-ready PDF format and Google Sheets files. You own the data forever and can share it with your marketing team, agency, or stakeholders."
  },
  {
    question: "Do you cover businesses outside Maharashtra?",
    answer: "Yes, we cover businesses across all states and Union Territories in India, analyzing regional preferences, languages, and competitor footprints specific to your state or city."
  },
  {
    question: "What industries do you cover?",
    answer: "We cover all major Indian consumer sectors including Real Estate, Jewellery, Healthcare, Education, E-commerce, B2B Manufacturing, Hospitality, Professional Services, and Retail."
  },
  {
    question: "Is there a refund policy for reports?",
    answer: "We invest significant manual analyst hours into deep-diving your market. While we do not offer refunds once research begins, we provide a satisfaction commitment—we will run revisions and additional competitor audits until you are completely satisfied with the report details."
  },
  {
    question: "Can I upgrade from Chakshu to Divya Drishti later?",
    answer: "Yes, you can upgrade your package within 14 days of receiving your Chakshu report by simply paying the difference."
  }
];

// JSON Schema generators
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Bodhi Drishti Research Reports",
  "description": "Competitor analysis, market research & growth intelligence reports for Indian businesses.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "RoasBodhi"
  },
  "areaServed": "IN",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Bodhi Drishti Plans",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Chakshu Research Report"
        },
        "price": "4999",
        "priceCurrency": "INR"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Divya Drishti Research Report"
        },
        "price": "14999",
        "priceCurrency": "INR"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Trikaldarshi Research Report"
        },
        "price": "29999",
        "priceCurrency": "INR"
      }
    ]
  }
};
---

<BaseLayout 
  title={pageTitle} 
  description={pageDescription} 
  keywords="competitor analysis India, market research agency, business intelligence report, competitor strategy, local market analysis"
>
  
  <!-- 1. URGENCY BAR -->
  <div class="bg-gradient-to-r from-secondary-purple to-primary-indigo py-2.5 text-center text-white text-xs font-display font-extrabold uppercase tracking-widest sticky top-0 z-50 select-none shadow-md">
    <div class="max-w-7xl mx-auto px-4 flex flex-wrap items-center justify-center gap-2">
      <span class="flex items-center gap-1">⚡ Drishti Utsav Launch Offer: </span>
      <span id="utsav-countdown" class="font-mono text-xs bg-black/20 px-2 py-0.5 rounded">
        Calculating...
      </span>
      <span class="hidden sm:inline">•</span>
      <span>Only <span id="spots-left" class="text-primary-gold font-bold">4</span> Slots Remaining at {val4999}!</span>
    </div>
  </div>

  <Header />

  <main class="flex-grow pt-20">
    
    <!-- ===================================================================
         SECTION 1: HERO
         =================================================================== -->
    <section class="relative bg-primary-indigo text-white py-24 lg:py-32 overflow-hidden select-none">
      <!-- Glow orbs background -->
      <div class="absolute left-[-100px] top-[10%] w-[350px] h-[350px] bg-secondary-purple/20 rounded-full blur-[120px] pointer-events-none"></div>
      <div class="absolute right-[-100px] bottom-[10%] w-[450px] h-[450px] bg-secondary-blue/15 rounded-full blur-[140px] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          
          <!-- LEFT COLUMN -->
          <div class="lg:col-span-7 text-left flex flex-col gap-6">
            <div class="inline-flex items-center gap-2 self-start px-3.5 py-1.5 rounded-full bg-secondary-purple/10 border border-secondary-purple/20 text-[10px] font-display font-extrabold uppercase tracking-widest text-secondary-purple bg-clip-border relative overflow-hidden group">
              <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-shimmer"></span>
              <span>🔬 New Service</span>
              <span class="text-white/40">•</span>
              <span class="text-white/95 font-body">Bodhi Drishti — Sacred Business Intelligence</span>
            </div>
            
            <h1 class="font-display font-extrabold text-4xl sm:text-6xl tracking-tight leading-[1.05]">
              Stop Guessing. <br />
              <span class="bg-gradient-to-r from-secondary-purple to-secondary-blue bg-clip-text text-transparent">Start Knowing.</span>
            </h1>
            
            <p class="font-body text-sm sm:text-base text-white/80 leading-relaxed font-semibold max-w-xl">
              Professional research reports that reveal exactly what your competitors are doing, what your market wants, and how to dominate — starting at just {val4999} one-time.
            </p>
            
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[10px] font-display font-extrabold uppercase tracking-widest text-white/50">
              <span class="flex items-center gap-1">📊 50+ Page Reports</span>
              <span>•</span>
              <span class="flex items-center gap-1">🔍 5+ Competitors Analyzed</span>
              <span>•</span>
              <span class="flex items-center gap-1">📞 Expert Consulting Included</span>
            </div>
            
            <div class="flex flex-wrap items-center gap-4 mt-2">
              <a href="#pricing-tiers" class="px-7 py-3.5 bg-gradient-to-r from-secondary-purple to-secondary-blue text-white font-display font-extrabold text-xs uppercase tracking-wider rounded-xl hover:shadow-button-purple hover:-translate-y-0.5 transition-all duration-300">
                Choose Your Report ↓
              </a>
              <a href="#sample-preview" class="px-7 py-3.5 border border-white/20 hover:bg-white/5 text-white font-display font-extrabold text-xs uppercase tracking-wider rounded-xl transition-all duration-300">
                See Sample Report
              </a>
            </div>
          </div>

          <!-- RIGHT COLUMN: REPORT MOCKUP -->
          <div class="lg:col-span-5 flex justify-center relative select-none">
            <!-- Mockup container with float animation -->
            <div class="relative w-72 sm:w-80 h-96 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-4 shadow-2xl animate-float-slow">
              <!-- Fan pages behind -->
              <div class="absolute -z-10 w-full h-full bg-white/5 border border-white/5 rounded-2xl top-2 -right-4 rotate-3"></div>
              <div class="absolute -z-20 w-full h-full bg-white/5 border border-white/5 rounded-2xl top-4 -right-8 rotate-6"></div>
              
              <!-- Report Cover Layout -->
              <div class="w-full h-full border border-white/10 rounded-xl bg-gradient-to-b from-[#15192E] to-[#0D1020] p-6 flex flex-col justify-between relative overflow-hidden">
                <!-- Watermark -->
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(124,58,237,0.08),transparent)] pointer-events-none"></div>
                
                <div class="flex items-center justify-between z-10">
                  <div class="flex items-center gap-1.5">
                    <div class="w-2.5 h-2.5 rounded-full bg-secondary-purple animate-ping"></div>
                    <span class="font-mono text-[9px] text-white/40 uppercase tracking-widest">Market Intelligence</span>
                  </div>
                  <span class="px-2 py-0.5 rounded border border-red-500/30 text-red-400 font-display font-extrabold text-[8px] uppercase tracking-widest select-none">
                    Confidential
                  </span>
                </div>
                
                <div class="flex flex-col gap-2 my-auto z-10">
                  <span class="text-xs font-display font-bold text-primary-gold tracking-widest uppercase">Bodhi Drishti</span>
                  <h2 class="font-display font-extrabold text-2xl text-white tracking-tight leading-snug">
                    Competitor & Market Research
                  </h2>
                  <div class="w-12 h-1 bg-gradient-to-r from-secondary-purple to-secondary-blue rounded-full"></div>
                </div>

                <div class="border-t border-white/5 pt-4 flex flex-col gap-1.5 z-10 text-left">
                  <span class="text-[9px] font-body text-white/50 uppercase tracking-wider">Prepared For:</span>
                  <span class="text-xs font-display font-bold text-white/90">Your Business Brand</span>
                  <div class="flex justify-between items-center mt-2 border-t border-white/5 pt-2">
                    <span class="text-[8px] font-mono text-white/40">RoasBodhi™ Systems</span>
                    <span class="text-[8px] font-mono text-white/40">v2.4</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
        </div>
      </div>
    </section>

    <!-- ===================================================================
         SECTION 2: PROBLEM AGITATION
         =================================================================== -->
    <section class="py-24 bg-neutral-ghost select-none">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <span class="font-display font-extrabold text-xs text-secondary-purple uppercase tracking-widest">
            Sound Familiar?
          </span>
          <h2 class="font-display font-extrabold text-neutral-dark text-3xl sm:text-5xl mt-3 tracking-tight">
            The Cost of Blind Operations
          </h2>
          <p class="font-body text-sm sm:text-base text-neutral-stone mt-3 font-semibold">
            Operating a business without active competitor metrics is like driving on a highway with your eyes closed.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <!-- Card 1 -->
          <div class="bg-white border border-neutral-mist rounded-2xl p-6 text-left shadow-sm hover:-translate-y-1 hover:border-secondary-purple/30 hover:shadow-card-hover transition-all duration-300 flex flex-col gap-4">
            <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center text-lg select-none">😤</div>
            <div>
              <h4 class="font-display font-extrabold text-xs text-neutral-dark tracking-wide uppercase">Blind Ad Spend</h4>
              <p class="font-body text-xs text-neutral-charcoal font-semibold mt-1">Spending on ads but no idea what competitors do.</p>
              <p class="font-body text-[10px] text-neutral-stone font-semibold mt-1">Consequence: High Customer Acquisition Costs (CAC) because you fail to differentiate your offer.</p>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="bg-white border border-neutral-mist rounded-2xl p-6 text-left shadow-sm hover:-translate-y-1 hover:border-secondary-purple/30 hover:shadow-card-hover transition-all duration-300 flex flex-col gap-4">
            <div class="w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center text-lg select-none">🤷</div>
            <div>
              <h4 class="font-display font-extrabold text-xs text-neutral-dark tracking-wide uppercase">Gut-Based Decisions</h4>
              <p class="font-body text-xs text-neutral-charcoal font-semibold mt-1">Making decisions based on gut feeling, not data.</p>
              <p class="font-body text-[10px] text-neutral-stone font-semibold mt-1">Consequence: Launching services or products that have zero regional search demand.</p>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="bg-white border border-neutral-mist rounded-2xl p-6 text-left shadow-sm hover:-translate-y-1 hover:border-secondary-purple/30 hover:shadow-card-hover transition-all duration-300 flex flex-col gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-lg select-none">⏰</div>
            <div>
              <h4 class="font-display font-extrabold text-xs text-neutral-dark tracking-wide uppercase">Zero Research Time</h4>
              <p class="font-body text-xs text-neutral-charcoal font-semibold mt-1">No time to research market trends yourself.</p>
              <p class="font-body text-[10px] text-neutral-stone font-semibold mt-1">Consequence: Missing key local micro-trends until your competitors have already captured the market.</p>
            </div>
          </div>

          <!-- Card 4 -->
          <div class="bg-white border border-neutral-mist rounded-2xl p-6 text-left shadow-sm hover:-translate-y-1 hover:border-secondary-purple/30 hover:shadow-card-hover transition-all duration-300 flex flex-col gap-4">
            <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center text-lg select-none">💸</div>
            <div>
              <h4 class="font-display font-extrabold text-xs text-neutral-dark tracking-wide uppercase">Keyword Leaks</h4>
              <p class="font-body text-xs text-neutral-charcoal font-semibold mt-1">Wasting money on wrong keywords and channels.</p>
              <p class="font-body text-[10px] text-neutral-stone font-semibold mt-1">Consequence: Buying high-competition clicks that never turn into phone calls or qualified leads.</p>
            </div>
          </div>

          <!-- Card 5 -->
          <div class="bg-white border border-neutral-mist rounded-2xl p-6 text-left shadow-sm hover:-translate-y-1 hover:border-secondary-purple/30 hover:shadow-card-hover transition-all duration-300 flex flex-col gap-4">
            <div class="w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center text-lg select-none">😰</div>
            <div>
              <h4 class="font-display font-extrabold text-xs text-neutral-dark tracking-wide uppercase">Pricing Ambiguity</h4>
              <p class="font-body text-xs text-neutral-charcoal font-semibold mt-1">Not sure if your pricing is competitive.</p>
              <p class="font-body text-[10px] text-neutral-stone font-semibold mt-1">Consequence: Leaving money on the table or losing customers over small, unoptimized price differences.</p>
            </div>
          </div>

          <!-- Card 6 -->
          <div class="bg-white border border-neutral-mist rounded-2xl p-6 text-left shadow-sm hover:-translate-y-1 hover:border-secondary-purple/30 hover:shadow-card-hover transition-all duration-300 flex flex-col gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-lg select-none">🔒</div>
            <div>
              <h4 class="font-display font-extrabold text-xs text-neutral-dark tracking-wide uppercase">Lagging Behind</h4>
              <p class="font-body text-xs text-neutral-charcoal font-semibold mt-1">Competitors growing faster and you don't know why.</p>
              <p class="font-body text-[10px] text-neutral-stone font-semibold mt-1">Consequence: Slowly losing market share as competitor search visibility and social reach scales up.</p>
            </div>
          </div>

        </div>

        <div class="mt-12 text-center">
          <p class="font-display font-extrabold text-sm sm:text-base text-neutral-charcoal">
            If you said yes to even <span class="text-secondary-purple">ONE</span> of these — Bodhi Drishti was made for you.
          </p>
        </div>

      </div>
    </section>

    <!-- ===================================================================
         SECTION 3: SOLUTION INTRODUCTION
         =================================================================== -->
    <section class="py-24 bg-white select-none">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          
          <!-- LEFT -->
          <div class="text-left flex flex-col gap-6">
            <span class="font-display font-extrabold text-xs text-secondary-purple uppercase tracking-widest">
              What if you could SEE everything?
            </span>
            <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-neutral-dark tracking-tight leading-tight">
              Unlock Professional-Grade <br />
              <span class="bg-gradient-to-r from-secondary-purple to-secondary-blue bg-clip-text text-transparent">Market Insight & Blueprint</span>
            </h2>
            <p class="font-body text-xs sm:text-sm text-neutral-charcoal leading-relaxed font-semibold">
              <strong>Bodhi Drishti (Sacred Vision)</strong> is our professional research intelligence service. We use advanced analysis tools and expert interpretation to create comprehensive reports that reveal your competitive landscape, market opportunities, and growth strategies.
            </p>
            <p class="font-body text-xs sm:text-sm text-neutral-stone leading-relaxed font-semibold">
              Think of it as hiring a {val50000}/month business consultant — but paying a small one-time fee of {val4999} to {val29999} and receiving a permanent, actionable strategy document that you can reference forever.
            </p>
          </div>

          <!-- RIGHT: STATS GRID -->
          <div class="grid grid-cols-2 gap-4">
            
            <div class="bg-neutral-ghost border border-neutral-mist/50 p-5 rounded-2xl text-center flex flex-col items-center justify-center gap-3">
              <div class="w-10 h-10 rounded-full bg-secondary-purple/10 flex items-center justify-center text-secondary-purple">
                <FileText class="w-5 h-5" />
              </div>
              <div class="flex flex-col">
                <span class="font-display font-extrabold text-lg text-neutral-dark leading-none">25-100+</span>
                <span class="font-body text-[10px] text-neutral-stone font-bold uppercase mt-1">Pages of Insights</span>
              </div>
            </div>

            <div class="bg-neutral-ghost border border-neutral-mist/50 p-5 rounded-2xl text-center flex flex-col items-center justify-center gap-3">
              <div class="w-10 h-10 rounded-full bg-secondary-purple/10 flex items-center justify-center text-secondary-purple">
                <Users class="w-5 h-5" />
              </div>
              <div class="flex flex-col">
                <span class="font-display font-extrabold text-lg text-neutral-dark leading-none">3-10</span>
                <span class="font-body text-[10px] text-neutral-stone font-bold uppercase mt-1">Competitors Audited</span>
              </div>
            </div>

            <div class="bg-neutral-ghost border border-neutral-mist/50 p-5 rounded-2xl text-center flex flex-col items-center justify-center gap-3">
              <div class="w-10 h-10 rounded-full bg-secondary-purple/10 flex items-center justify-center text-secondary-purple">
                <Clock class="w-5 h-5" />
              </div>
              <div class="flex flex-col">
                <span class="font-display font-extrabold text-lg text-neutral-dark leading-none">5-15 Days</span>
                <span class="font-body text-[10px] text-neutral-stone font-bold uppercase mt-1">Fast Delivery</span>
              </div>
            </div>

            <div class="bg-neutral-ghost border border-neutral-mist/50 p-5 rounded-2xl text-center flex flex-col items-center justify-center gap-3">
              <div class="w-10 h-10 rounded-full bg-secondary-purple/10 flex items-center justify-center text-secondary-purple">
                <Phone class="w-5 h-5" />
              </div>
              <div class="flex flex-col">
                <span class="font-display font-extrabold text-lg text-neutral-dark leading-none">Consulting</span>
                <span class="font-body text-[10px] text-neutral-stone font-bold uppercase mt-1">Calls Included</span>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- ===================================================================
         SECTION 4: WHAT'S INSIDE THE REPORT (INTERACTIVE TABS)
         =================================================================== -->
    <section class="py-24 bg-primary-indigo text-white select-none relative overflow-hidden">
      <!-- Glow decoration -->
      <div class="absolute left-[-200px] bottom-[10%] w-[400px] h-[400px] bg-secondary-purple/15 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <span class="font-display font-extrabold text-xs text-secondary-purple uppercase tracking-widest">
            Deep-Dive Chapters
          </span>
          <h2 class="font-display font-extrabold text-3xl sm:text-5xl mt-3 tracking-tight">
            What You'll Get Inside
          </h2>
          <p class="font-body text-sm sm:text-base text-white/70 mt-3 font-semibold">
            Every chapter is built manually by our strategic analysts to provide absolute clarity.
          </p>
        </div>

        <!-- TABS SWITCHER -->
        <div class="flex justify-center mb-10 overflow-x-auto pb-2 scrollbar-none">
          <div class="inline-flex p-1 bg-white/5 border border-white/10 rounded-full" id="report-tab-switcher">
            <button class="px-4 py-2.5 rounded-full text-xs font-display font-bold uppercase tracking-wider bg-white text-primary-indigo shadow-md tab-btn active" data-tab="competitor">
              🔍 Competitor Intelligence
            </button>
            <button class="px-4 py-2.5 rounded-full text-xs font-display font-bold uppercase tracking-wider text-white/70 hover:text-white tab-btn" data-tab="market">
              📊 Market Research
            </button>
            <button class="px-4 py-2.5 rounded-full text-xs font-display font-bold uppercase tracking-wider text-white/70 hover:text-white tab-btn" data-tab="keyword">
              🎯 Keyword & SEO
            </button>
            <button class="px-4 py-2.5 rounded-full text-xs font-display font-bold uppercase tracking-wider text-white/70 hover:text-white tab-btn" data-tab="ad">
