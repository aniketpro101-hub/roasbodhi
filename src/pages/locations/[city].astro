---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CityHero from '../../components/sections/CityHero.astro';
import LocalInsights from '../../components/sections/LocalInsights.astro';
import CityServices from '../../components/sections/CityServices.astro';
import PricingPreview from '../../components/sections/PricingPreview.astro';
import ResultsSection from '../../components/sections/ResultsSection.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import CtaSection from '../../components/sections/CtaSection.astro';
import { MapPin, Users, Briefcase } from 'lucide-astro';

// Load our databases
import citiesData from '../../data/cities.json';
import servicesData from '../../data/services.json';

// Import Schema Utilities
import { generateLocalBusinessSchema, generateFAQSchema, generateBreadcrumbSchema } from '../../utils/schema';

// Import FAQ Content Builder
import { generateCitySpecificFAQs } from '../../utils/content-generator';

export async function getStaticPaths() {
  return citiesData.map(city => ({
    params: {
      city: city.slug
    },
    props: {
      city
    }
  }));
}

interface Props {
  city: typeof citiesData[0];
}

const { city } = Astro.props;

// Default "General Digital Marketing" service mock parameters to feed the Hero and LocalInsights layout wrappers
const mockService = {
  id: 'performance-marketing',
  name: 'Digital Marketing Services',
  slug: 'performance-marketing',
  short_name: 'Digital Marketing',
  color: '#FF6B2B',
  gradient: 'from-[#FF6B2B] to-[#F5A623]',
  description: 'Specialized local lead generation and high-speed web optimization retainers.'
};

const pageTitle = `Digital Marketing Agency in ${city.name} | Performance Marketing ${city.name} - RoasBodhi`;
const pageDescription = `Looking for the best digital marketing agency in ${city.name}? RoasBodhi™ delivers performance Meta/Google ads and web design optimized for ${city.name} businesses.`;

const localSchema = generateLocalBusinessSchema(city);
const stateSlug = city.state_slug || city.state.toLowerCase().replace(/\s+/g, '-');
const breadcrumbSchema = generateBreadcrumbSchema([
  { label: 'Locations', href: '/locations/' },
  { label: city.state, href: `/locations/${stateSlug}/` },
  { label: city.name, href: `/locations/${city.slug}/` }
]);

// Build city-specific FAQs
const localFaqs = generateCitySpecificFAQs(city, "Digital Marketing");
const faqSchema = generateFAQSchema(localFaqs);

const combinedSchema = {
  "@context": "https://schema.org",
  "@graph": [
    localSchema,
    breadcrumbSchema,
    faqSchema
  ]
};
const cityKeywords = `digital marketing agency in ${city.name}, performance marketing agency in ${city.name}, meta ads agency ${city.name}, google ads expert ${city.name}`;
---

<BaseLayout title={pageTitle} description={pageDescription} keywords={cityKeywords} schema={combinedSchema}>
  
  <Header />

  <main class="flex-grow">
    
    <!-- 1. City Hero Section -->
    <CityHero city={city} service={mockService} />

    <!-- 2. Local Market Insights -->
    <LocalInsights city={city} service={mockService} />

    <!-- 3. Services Offered Grid -->
    <CityServices city={city} activeServiceSlug="" />

    <!-- 4. Verified Results Cases -->
    <ResultsSection />

    <!-- 5. Simplified Pricing Preview -->
    <PricingPreview />

    <!-- 6. Local FAQ Accordion -->
    <section class="py-24 bg-white select-none">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center flex flex-col items-center gap-3 max-w-3xl mx-auto mb-16">
          <span class="font-display font-extrabold text-xs text-primary-saffron uppercase tracking-widest">
            FAQ DIRECTORY
          </span>
          <h2 class="font-display font-extrabold text-neutral-dark text-3xl sm:text-5xl tracking-tight mt-2">
            Local Marketing FAQs for <br />
            <span class="bg-gradient-to-r from-primary-saffron to-primary-gold bg-clip-text text-transparent">{city.name} Storefronts</span>
          </h2>
        </div>

        <FAQAccordion faqs={localFaqs} />
      </div>
    </section>

    <!-- 7. Nearby Cities Links -->
    <section class="py-24 bg-neutral-ghost border-t border-neutral-mist select-none text-neutral-charcoal">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="font-display font-extrabold text-xs text-primary-saffron uppercase tracking-widest">
          PAN-INDIA DIRECTORY
        </span>
        <h3 class="font-display font-extrabold text-2xl sm:text-4xl text-neutral-dark tracking-tight mt-3">
          Serving Nearby Towns & Cities
        </h3>

        <div class="grid grid-cols-1 sm:grid-cols-5 gap-4 mt-12 max-w-5xl mx-auto">
          {city.nearby_cities.map(nb => (
            <a 
              href={`/locations/${nb.slug}/`}
              class="p-5 rounded-2xl bg-white border border-neutral-mist hover:border-primary-saffron hover:shadow-card-default transition-all duration-300 flex flex-col items-start text-left gap-3 group"
            >
              <div class="flex items-center justify-between w-full">
                <span class="font-display font-extrabold text-xs text-neutral-dark group-hover:text-primary-saffron transition-colors">
                  {nb.name}
                </span>
                <MapPin class="w-3.5 h-3.5 text-neutral-stone group-hover:text-primary-saffron transition-colors flex-shrink-0" />
              </div>
              
              <div class="flex flex-col gap-1.5 font-body text-[10px] text-neutral-stone font-semibold mt-1">
                <span class="flex items-center gap-1 leading-none"><Users class="w-3 h-3 text-neutral-stone" /> Pop: {nb.population}</span>
                <span class="flex items-center gap-1 leading-none"><Briefcase class="w-3 h-3 text-neutral-stone" /> {nb.top_industry}</span>
              </div>
              
              <span class="text-[9px] font-display font-extrabold text-primary-saffron tracking-wider mt-2 border-t border-neutral-mist/50 pt-2 w-full text-center">
                {nb.distance_km} KM AWAY →
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 8. Audit CTA Form -->
    <CtaSection />

  </main>

  <Footer />

</BaseLayout>
