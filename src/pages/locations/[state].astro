---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import CtaSection from '../../components/sections/CtaSection.astro';
import { MapPin, ArrowRight } from 'lucide-astro';

// Load our databases
import citiesData from '../../data/cities.json';

// Static Paths generation for every unique state in cities.json
export async function getStaticPaths() {
  const uniqueStates = Array.from(new Set(citiesData.map(c => c.state)));
  
  return uniqueStates.map(state => {
    const stateSlug = state.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-');
    const citiesInState = citiesData.filter(c => c.state === state);
    
    return {
      params: {
        state: stateSlug
      },
      props: {
        state,
        cities: citiesInState
      }
    };
  });
}

interface Props {
  state: string;
  cities: typeof citiesData;
}

const { state, cities } = Astro.props;

const pageTitle = `Performance Marketing & Digital Services in ${state} | RoasBodhi™`;
const pageDescription = `Looking to grow your business in ${state}? Explore RoasBodhi™'s local advertising and website design services across ${cities.length} cities in ${state}.`;

// Build state-level local business schema index
const stateSchema = {
  "@context": "https://schema.org",
  "@type": "GovernmentOffice", // Governs this territory of local businesses served
  "name": `RoasBodhi™ ${state} Directory`,
  "url": `https://roasbodhi.in/locations/${state.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-')}/`,
  "address": {
    "@type": "PostalAddress",
    "addressRegion": state,
    "addressCountry": "IN"
  }
};
const stateKeywords = `digital marketing agency in ${state}, performance marketing ${state}, local SEO services ${state}`;
---

<BaseLayout title={pageTitle} description={pageDescription} keywords={stateKeywords} schema={stateSchema}>
  
  <Header />

  <main class="flex-grow pt-28 pb-16 bg-neutral-ghost">
    
    <!-- Hero Hub Header -->
    <section class="py-20 bg-neutral-dark text-white text-center relative overflow-hidden select-none">
      <div class="absolute inset-0 bg-[radial-gradient(#ffffff04_1px,transparent_1px)] bg-[size:16px_16px]"></div>
      
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col items-center gap-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] font-display font-extrabold uppercase tracking-widest text-white">
          📍 Territory Hub
        </span>
        <h1 class="font-display font-extrabold text-3xl sm:text-5xl text-white tracking-tight leading-tight">
          Performance Marketing <br />
          <span class="bg-gradient-to-r from-primary-saffron to-primary-gold bg-clip-text text-transparent">Across {state}</span>
        </h1>
        <p class="font-body text-xs sm:text-sm text-white/70 max-w-xl leading-relaxed mt-2 font-medium">
          Awakening return-on-ad-spend and fast local websites for businesses operating in {state}. 
          Select your city below to get customized local marketing solutions.
        </p>
      </div>
    </section>

    <!-- State Cities Directory Grid -->
    <section class="py-24 bg-white select-none">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center flex flex-col items-center gap-3 max-w-3xl mx-auto mb-16">
          <SectionLabel text="CITY DIRECTORY" />
          <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-neutral-dark tracking-tight mt-2">
            Select Your City in {state}
          </h2>
          <p class="font-body text-xs sm:text-sm text-neutral-stone font-semibold mt-1">
            We serve {cities.length} local commercial centers across the state.
          </p>
        </div>

        <!-- Cities list grid -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-5xl mx-auto text-left">
          {cities.map(city => (
            <a 
              href={`/locations/${city.slug}/`}
              class="p-4 rounded-xl bg-neutral-ghost border border-neutral-mist hover:border-primary-saffron hover:bg-white hover:shadow-card-default transition-all duration-300 flex items-center justify-between group"
            >
              <div class="flex items-center gap-2">
                <MapPin class="w-3.5 h-3.5 text-neutral-stone group-hover:text-primary-saffron transition-colors" />
                <span class="font-display font-bold text-xs text-neutral-dark leading-none">
                  {city.name}
                </span>
              </div>
              <ArrowRight class="w-3.5 h-3.5 text-neutral-stone/50 group-hover:translate-x-0.5 group-hover:text-primary-saffron transition-all" />
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- Lead Form Capture -->
    <CtaSection />

  </main>

  <Footer />

</BaseLayout>
