---
import { Play, Sparkles, Star } from 'lucide-astro';
---

<section class="relative min-h-screen flex items-center bg-neutral-dark overflow-hidden pt-24 pb-16">
  
  <!-- Background Layers -->
  <div class="absolute inset-0 z-0">
    <!-- Grid Overlay (opacity 0.04) -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff0a_1px,transparent_1px),linear-gradient(to_bottom,#ffffff0a_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    
    <!-- Glowing Blur Blobs -->
    <div class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-primary-saffron/10 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-1/4 left-0 w-[400px] h-[400px] bg-secondary-purple/10 rounded-full blur-[100px]"></div>
    <div class="absolute top-1/2 left-1/3 w-[300px] h-[300px] bg-primary-gold/5 rounded-full blur-[80px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Left Column: Copy & CTAs -->
      <div class="lg:col-span-7 flex flex-col items-start text-left">
        
        <!-- Shimmer Pill Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-secondary-purple/15 border border-secondary-purple/35 shadow-cta-glow mb-6 relative overflow-hidden group">
          <!-- Shimmer Line -->
          <div class="absolute inset-0 w-1/2 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-out"></div>
          <Sparkles class="w-4 h-4 text-primary-gold" />
          <span class="font-display font-bold text-xs text-white tracking-wider">
            India's #1 Sacred Performance Agency
          </span>
        </div>

        <!-- H1 Headline with Text Cycler -->
        <h1 class="font-display font-extrabold text-white text-4xl sm:text-5xl lg:text-[76px] leading-[1.05] tracking-tight mb-6">
          Awakening Your <br />
          <span id="cycle-word" class="bg-gradient-to-r from-primary-saffron to-primary-gold bg-clip-text text-transparent inline-block min-w-[280px]">Ad Returns</span>
        </h1>

        <!-- Subheadline -->
        <p class="font-body text-base sm:text-lg text-white/70 max-w-xl leading-relaxed mb-8">
          Meta Ads • Google Ads • Web Design • GMB Setup & Growth.<br />
          We scale Indian SMBs with programmatic SEO and high-converting performance marketing.
        </p>

        <!-- CTAs Grid -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 w-full sm:w-auto mb-10">
          <a href="/contact/" class="px-8 py-4 font-display font-extrabold text-sm text-center text-white rounded-full bg-gradient-to-r from-primary-saffron to-primary-gold hover:scale-[1.02] shadow-button-saffron hover:shadow-cta-glow transition-all duration-300 animate-pulse-saffron">
            🚀 Get Free ROAS Audit
          </a>
          <a href="https://wa.me/9082543992?text=Namaste%20RoasBodhi%E2%84%A2!%20I'd%20like%20to%20consult%20on%20web%20design%20and%20ads%20for%20my%20business." target="_blank" rel="noopener noreferrer" class="px-8 py-4 font-display font-extrabold text-sm text-center text-white rounded-full bg-white/10 border border-white/20 hover:bg-white/15 transition-all duration-200 flex items-center justify-center gap-2">
            <Play class="w-4 h-4 text-primary-gold fill-primary-gold" />
            Consult on WhatsApp
          </a>
        </div>

        <!-- Social Proof Metric Row -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 w-full pt-8 border-t border-white/10">
          <div class="flex flex-col gap-1 border-r border-white/10 pr-2">
            <span class="flex items-center gap-1">
              <Star class="w-3.5 h-3.5 fill-primary-gold text-primary-gold" />
              <Star class="w-3.5 h-3.5 fill-primary-gold text-primary-gold" />
              <Star class="w-3.5 h-3.5 fill-primary-gold text-primary-gold" />
              <Star class="w-3.5 h-3.5 fill-primary-gold text-primary-gold" />
              <Star class="w-3.5 h-3.5 fill-primary-gold text-primary-gold" />
            </span>
            <span class="font-body text-xs text-white/50">4.9/5 Rating (47 Reviews)</span>
          </div>
          <div class="flex flex-col gap-1 border-r border-white/10 pr-2">
            <span class="font-mono font-bold text-base text-primary-saffron">₹2Cr+</span>
            <span class="font-body text-[10px] text-white/50 uppercase tracking-wider">Ad Spend Optimized</span>
          </div>
          <div class="flex flex-col gap-1 sm:border-r sm:border-white/10 pr-2">
            <span class="font-mono font-bold text-base text-secondary-purple">200+</span>
            <span class="font-body text-[10px] text-white/50 uppercase tracking-wider">SMBs Transformed</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="font-mono font-bold text-base text-secondary-blue">180+</span>
            <span class="font-body text-[10px] text-white/50 uppercase tracking-wider">Cities Served</span>
          </div>
        </div>

      </div>

      <!-- Right Column: Interactive Browser Dashboard Mockup -->
      <div class="lg:col-span-5 relative w-full flex justify-center">
        <!-- Floating Glassmorphic Container with 3D Tilt Hover Effect -->
        <div id="hero-mockup" class="w-full max-w-[440px] bg-white/5 backdrop-blur-xl border border-white/12 rounded-2xl shadow-[0_40px_80px_rgba(0,0,0,0.40)] p-5 select-none transition-transform duration-500 ease-out animate-float relative z-10 flex flex-col gap-5">
          
          <!-- Mockup Browser Header -->
          <div class="flex items-center justify-between pb-3 border-b border-white/10">
            <div class="flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-rose-500"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-amber-500"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
            </div>
            <div class="text-[10px] font-mono text-white/40">analytics.roasbodhi.in</div>
            <span class="w-4 h-4"></span>
          </div>

          <!-- Main Metric Cards Grid -->
          <div class="grid grid-cols-2 gap-3.5">
            <div class="bg-white/5 p-3 rounded-xl border border-white/5 flex flex-col">
              <span class="text-[10px] text-white/50 uppercase tracking-wider">Total Ad Spend</span>
              <span class="font-mono font-bold text-lg text-white mt-1">₹4,82,910</span>
              <span class="text-[9px] text-white/40 mt-1">Last 30 Days</span>
            </div>
            <div class="bg-white/5 p-3 rounded-xl border border-white/5 flex flex-col">
              <span class="text-[10px] text-white/50 uppercase tracking-wider">Total Revenue</span>
              <span class="font-mono font-bold text-lg text-secondary-emerald mt-1">₹20,28,220</span>
              <span class="text-[9px] text-secondary-emerald mt-1 font-semibold">📈 +127% Increase</span>
            </div>
          </div>

          <!-- Growth Chart Mockup -->
          <div class="bg-white/5 p-4 rounded-xl border border-white/5 flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <span class="text-[10px] text-white/60 font-semibold">ROAS Awakening Scale</span>
              <!-- Saffron Badge -->
              <span class="px-2 py-0.5 rounded-full bg-emerald-500/20 text-secondary-emerald font-mono font-bold text-[9px]">
                Target Achieved: 4.2X
              </span>
            </div>
            
            <!-- Graphic growth wave (pure HTML/CSS) -->
            <div class="h-28 flex items-end justify-between gap-1.5 pt-4 relative">
              <!-- Y-Axis labels -->
              <div class="absolute left-0 top-0 bottom-0 flex flex-col justify-between text-[8px] text-white/30 font-mono">
                <span>5.0x</span>
                <span>3.0x</span>
                <span>1.0x</span>
              </div>
              <div class="w-full h-[1px] bg-white/10 absolute bottom-0 left-0"></div>
              
              <!-- Bars representing upward growth trend -->
              <div class="w-full bg-white/10 rounded-t h-[20%] ml-6"></div>
              <div class="w-full bg-white/10 rounded-t h-[28%]"></div>
              <div class="w-full bg-white/15 rounded-t h-[35%]"></div>
              <div class="w-full bg-gradient-to-t from-primary-saffron/30 to-primary-saffron/80 rounded-t h-[52%]"></div>
              <div class="w-full bg-gradient-to-t from-primary-saffron/30 to-primary-saffron/80 rounded-t h-[68%]"></div>
              <div class="w-full bg-gradient-to-t from-primary-gold/40 to-primary-gold/90 rounded-t h-[92%] relative">
                <!-- Glowing point on peak ROAS bar -->
                <span class="absolute -top-1 left-1/2 -translate-x-1/2 w-2 h-2 rounded-full bg-white shadow-cta-glow"></span>
              </div>
            </div>
            
            <!-- Timeline X-Axis -->
            <div class="flex justify-between text-[8px] text-white/30 font-mono pl-6">
              <span>Week 1 (Audits)</span>
              <span>Week 3 (Agni launch)</span>
              <span>Week 6 (Bodhi Scale)</span>
            </div>
          </div>

          <!-- Bottom Meta & Google Ad Status indicator -->
          <div class="flex items-center justify-between text-[10px] text-white/60 bg-white/5 p-3 rounded-xl border border-white/5">
            <span class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
              <span>Active Channels: Meta + Google Ads</span>
            </span>
            <span class="font-mono text-primary-gold font-bold">4.2X ROAS</span>
          </div>

        </div>

        <!-- Floating Badges Layer on top of Mockup -->
        <div class="absolute -top-6 -left-6 z-20 px-4 py-2 bg-emerald-500 rounded-xl border border-emerald-400/30 text-white shadow-lg flex items-center gap-2 transform -rotate-6 select-none">
          <span class="text-lg">🔥</span>
          <div class="flex flex-col">
            <span class="font-display font-extrabold text-xs tracking-wide">3.8X ROAS</span>
            <span class="text-[8px] font-body text-white/80">Average Delivered</span>
          </div>
        </div>

        <div class="absolute -bottom-6 -right-6 z-20 px-4 py-2 bg-primary-indigo rounded-xl border border-white/10 text-white shadow-lg flex items-center gap-2 transform rotate-6 select-none">
          <span class="text-lg">📈</span>
          <div class="flex flex-col">
            <span class="font-display font-extrabold text-xs tracking-wide">+127% Leads</span>
            <span class="text-[8px] font-body text-white/80">Growth in 30 Days</span>
          </div>
        </div>

      </div>

    </div>
  </div>

</section>

<script>
  // Word Cycler (Typewriter effect) for Hero Headline
  const cycleWord = document.getElementById('cycle-word');
  const words = ['Ad Returns', 'ROAS', 'Revenue', 'Growth'];
  let wordIndex = 0;

  function changeWord() {
    if (!cycleWord) return;
    
    // Smooth transition
    cycleWord.style.opacity = '0';
    cycleWord.style.transform = 'translateY(-10px)';
    
    setTimeout(() => {
      wordIndex = (wordIndex + 1) % words.length;
      cycleWord.textContent = words[wordIndex];
      cycleWord.style.opacity = '1';
      cycleWord.style.transform = 'translateY(0)';
    }, 350);
  }

  // Set transition styles on word element
  if (cycleWord) {
    cycleWord.style.transition = 'all 350ms ease-in-out';
    setInterval(changeWord, 2500);
  }

  // 3D Tilt Effect on Desktop Hover for Mockup
  const mockup = document.getElementById('hero-mockup');
  
  if (mockup) {
    window.addEventListener('mousemove', (e) => {
      // Rotate dashboard slightly matching mouse relative position to screen center
      const x = (window.innerWidth / 2 - e.clientX) / 45;
      const y = (window.innerHeight / 2 - e.clientY) / 45;
      
      // limit tilt values
      const rx = Math.max(-8, Math.min(8, y));
      const ry = Math.max(-8, Math.min(8, -x));
      
      mockup.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-8px)`;
    });
    
    // Reset transform on mouse leave or idle
    window.addEventListener('mouseout', () => {
      mockup.style.transform = '';
    });
  }
</script>
