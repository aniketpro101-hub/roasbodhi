---
import { MessageCircle } from 'lucide-astro';
---

<div class="w-full bg-neutral-dark text-white rounded-2xl border border-white/10 p-6 sm:p-8 shadow-card-hover relative overflow-hidden">
  
  <!-- Background Glow -->
  <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-primary-saffron/10 rounded-full blur-[80px]"></div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center relative z-10">
    
    <!-- Left Column: Controls Sliders -->
    <div class="lg:col-span-7 flex flex-col gap-6">
      <div class="flex flex-col">
        <h3 class="font-display font-extrabold text-2xl text-white tracking-tight">
          Interactive ROAS Calculator
        </h3>
        <p class="font-body text-xs sm:text-sm text-white/60 mt-1">
          Adjust the sliders to see how awakening your returns increases your monthly profit.
        </p>
      </div>

      <!-- Slider 1: Monthly Ad Spend -->
      <div class="flex flex-col gap-2">
        <div class="flex items-center justify-between font-body text-xs sm:text-sm font-semibold">
          <span class="text-white/80">Monthly Ad Budget</span>
          <span class="font-mono text-primary-saffron text-base font-bold">
            ₹<span id="calc-spend-val">50,000</span>
          </span>
        </div>
        <input 
          type="range" 
          id="calc-spend" 
          min="10000" 
          max="500000" 
          step="5000" 
          value="50000"
          class="w-full h-2 bg-white/10 rounded-lg appearance-none cursor-pointer accent-primary-saffron"
        />
        <div class="flex justify-between text-[10px] text-white/40 font-mono">
          <span>₹10,000</span>
          <span>₹5,00,000</span>
        </div>
      </div>

      <!-- Slider 2: Current ROAS -->
      <div class="flex flex-col gap-2">
        <div class="flex items-center justify-between font-body text-xs sm:text-sm font-semibold">
          <span class="text-white/80">Current ROAS (Return on Ad Spend)</span>
          <span class="font-mono text-secondary-purple text-base font-bold">
            <span id="calc-roas-val">1.5</span>X
          </span>
        </div>
        <input 
          type="range" 
          id="calc-roas" 
          min="1.0" 
          max="5.0" 
          step="0.1" 
          value="1.5"
          class="w-full h-2 bg-white/10 rounded-lg appearance-none cursor-pointer accent-secondary-purple"
        />
        <div class="flex justify-between text-[10px] text-white/40 font-mono">
          <span>1.0X (Break Even)</span>
          <span>5.0X (High Return)</span>
        </div>
      </div>
      
      <!-- Target Bodhi ROAS explanation -->
      <div class="p-4 rounded-xl bg-white/5 border border-white/5 flex items-start gap-3">
        <span class="text-lg">🔱</span>
        <div class="flex flex-col">
          <span class="font-display font-bold text-xs text-primary-gold">The Bodhi Performance Target:</span>
          <span class="font-body text-[11px] text-white/70 mt-1 leading-relaxed">
            Based on our client audits, we aim to scale campaigns to a target of **3.5X to 5.0X ROAS** in the first 60 days.
          </span>
        </div>
      </div>
    </div>

    <!-- Right Column: Outputs Dashboard Display -->
    <div class="lg:col-span-5 flex flex-col gap-6 bg-white/5 p-6 rounded-xl border border-white/8">
      
      <!-- Current vs Projected Revenue breakdown -->
      <div class="flex flex-col gap-4">
        <!-- Current State -->
        <div class="flex justify-between items-center">
          <span class="text-xs text-white/60 font-medium">Current Revenue</span>
          <span class="font-mono text-sm text-white/80 font-bold" id="calc-curr-rev">
            ₹75,000
          </span>
        </div>
        
        <!-- Target Awakened State -->
        <div class="flex justify-between items-center pb-3 border-b border-white/10">
          <span class="text-xs text-primary-gold font-bold flex items-center gap-1">
            <span>✨</span> Awakened Target ROAS
          </span>
          <span class="font-mono text-sm text-primary-gold font-extrabold" id="calc-target-roas">
            4.0X
          </span>
        </div>

        <!-- Projected Revenue -->
        <div class="flex justify-between items-center">
          <span class="text-xs text-white/80 font-semibold">Projected Revenue</span>
          <span class="font-mono text-lg text-secondary-emerald font-extrabold" id="calc-proj-rev">
            ₹2,00,000
          </span>
        </div>
        
        <!-- Net Monthly Increase -->
        <div class="flex flex-col gap-1 bg-secondary-emerald/10 p-3 rounded-lg border border-secondary-emerald/20 text-center">
          <span class="text-[10px] text-secondary-emerald uppercase tracking-wider font-bold">Monthly Profit Increase</span>
          <span class="font-mono text-2xl font-extrabold text-secondary-emerald" id="calc-profit-inc">
            +₹1,25,000
          </span>
        </div>
      </div>

      <!-- Action CTA Button linking to WhatsApp with dynamic pre-filled text -->
      <a 
        id="calc-whatsapp-btn"
        href="https://wa.me/9082543992?text=Namaste%20RoasBodhi%E2%84%A2!%20I%20used%20your%20ROAS%20calculator.%20My%20ad%20budget%20is%20%E2%82%B950,000%20with%201.5X%20ROAS.%20I%27d%20like%20to%20get%20a%20free%20audit%20to%20reach%204.0X%20ROAS."
        target="_blank" 
        rel="noopener noreferrer" 
        class="flex items-center justify-center gap-2 py-3.5 bg-gradient-to-r from-primary-saffron to-primary-gold hover:shadow-button-saffron hover:-translate-y-0.5 rounded-xl font-display font-extrabold text-sm text-white tracking-wide transition-all duration-300"
      >
        <MessageCircle class="w-4 h-4 fill-white" />
        Unlock This ROAS on WhatsApp →
      </a>

    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const spendSlider = document.getElementById('calc-spend') as HTMLInputElement;
    const roasSlider = document.getElementById('calc-roas') as HTMLInputElement;
    
    const spendVal = document.getElementById('calc-spend-val')!;
    const roasVal = document.getElementById('calc-roas-val')!;
    const currRev = document.getElementById('calc-curr-rev')!;
    const targetRoasText = document.getElementById('calc-target-roas')!;
    const projRev = document.getElementById('calc-proj-rev')!;
    const profitInc = document.getElementById('calc-profit-inc')!;
    const waBtn = document.getElementById('calc-whatsapp-btn') as HTMLAnchorElement;

    const formatCurrency = (num: number): string => {
      return '₹' + Math.floor(num).toLocaleString('en-IN');
    };

    const updateCalculator = () => {
      if (!spendSlider || !roasSlider) return;

      const spend = parseFloat(spendSlider.value);
      const currentRoas = parseFloat(roasSlider.value);
      
      // Update Slider Display values
      spendVal.textContent = spend.toLocaleString('en-IN');
      roasVal.textContent = currentRoas.toFixed(1);

      // Current Revenue
      const currentRevenue = spend * currentRoas;
      currRev.textContent = formatCurrency(currentRevenue);

      // Target ROAS mapping logic (Awakened state is always higher, starting from 3.5X to 5.0X)
      let targetRoas = 4.0;
      if (currentRoas < 1.5) targetRoas = 3.5;
      else if (currentRoas >= 1.5 && currentRoas < 2.5) targetRoas = 4.0;
      else if (currentRoas >= 2.5 && currentRoas < 3.5) targetRoas = 4.5;
      else targetRoas = 5.0;

      targetRoasText.textContent = targetRoas.toFixed(1) + 'X';

      // Projected Revenue & Net Profit Increase
      const projectedRevenue = spend * targetRoas;
      const netProfitIncrease = projectedRevenue - currentRevenue;

      projRev.textContent = formatCurrency(projectedRevenue);
      profitInc.textContent = '+' + formatCurrency(netProfitIncrease);

      // Update Dynamic WhatsApp Pre-filled text URL Link
      const messageText = `Namaste RoasBodhi™! I used your ROAS calculator. My monthly ad budget is ${formatCurrency(spend)} with a current ROAS of ${currentRoas.toFixed(1)}X. I would like a free ads audit to target an awakened ${targetRoas.toFixed(1)}X ROAS.`;
      waBtn.href = `https://wa.me/9082543992?text=${encodeURIComponent(messageText)}`;
    };

    // Attach input event listeners for instant reactive calculation updates
    if (spendSlider && roasSlider) {
      spendSlider.addEventListener('input', updateCalculator);
      roasSlider.addEventListener('input', updateCalculator);
      // Run initial load
      updateCalculator();
    }
  });
</script>
