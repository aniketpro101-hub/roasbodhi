---
import { ArrowRight, MessageCircle } from 'lucide-astro';

interface Props {
  service: {
    id: string;
    name: string;
    slug: string;
    short_name: string;
    color: string;
    gradient: string;
    description: string;
    benefits: string[];
  };
}

const { service } = Astro.props;

const whatsappMsg = `Namaste RoasBodhi™! I'd like to consult on ${service.name} for my business.`;
const whatsappUrl = `https://wa.me/9082543992?text=${encodeURIComponent(whatsappMsg)}`;
---

<section class="relative bg-neutral-dark text-white py-24 sm:py-32 overflow-hidden select-none">
  
  <!-- Ambient service glow orbs -->
  <div 
    class="absolute -top-40 -right-40 w-96 h-96 rounded-full blur-[120px] opacity-15 pointer-events-none"
    style={`background-color: ${service.color};`}
  ></div>
  <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-primary-saffron/10 rounded-full blur-[100px] pointer-events-none"></div>

  <!-- Dot pattern overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(#ffffff04_1px,transparent_1px)] bg-[size:16px_16px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-left">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Left content -->
      <div class="lg:col-span-8 flex flex-col items-start gap-5 sm:gap-6">
        
        <!-- Category Badge -->
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] font-display font-extrabold uppercase tracking-widest text-white">
          <span>🔱 Category: Performance Marketing</span>
        </span>

        <!-- H1 -->
        <h1 class="font-display font-extrabold text-3xl sm:text-6xl text-white tracking-tight leading-[1.1] max-w-3xl">
          {service.name} <br />
          <span class="bg-gradient-to-r from-primary-saffron to-primary-gold bg-clip-text text-transparent">Management Agency India</span>
        </h1>

        <p class="font-body text-sm sm:text-base text-white/70 max-w-xl leading-relaxed">
          {service.description} We scale returns on ad spends and web conversions for Indian storefronts. 
          Enjoy Pay-After-Seeing™ protection and transparent, live report updates.
        </p>

        <!-- 3 benefits pills -->
        <div class="flex flex-wrap gap-2.5 mt-2">
          {service.benefits.slice(0, 3).map(benefit => (
            <span class="px-3 py-1 rounded-full bg-white/10 border border-white/5 text-[9px] font-display font-extrabold uppercase tracking-wide">
              ✓ {benefit}
            </span>
          ))}
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 w-full sm:w-auto mt-4">
          <a 
            href="#contact-form-section" 
            class="px-7 py-3.5 bg-gradient-to-r from-primary-saffron to-primary-gold text-white font-display font-extrabold text-xs tracking-wider uppercase rounded-full shadow-lg hover:shadow-button-saffron hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-1.5"
          >
            <span>🚀 Get Free {service.short_name} Audit</span>
            <ArrowRight class="w-4 h-4" />
          </a>
          
          <a 
            href={whatsappUrl} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="px-7 py-3.5 bg-emerald-600 hover:bg-emerald-700 text-white font-display font-extrabold text-xs tracking-wider uppercase rounded-full shadow-md hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-center gap-1.5"
          >
            <MessageCircle class="w-4.5 h-4.5 fill-white text-white" />
            <span>Consult on WhatsApp</span>
          </a>
        </div>

      </div>

      <!-- Right large icon indicator -->
      <div class="lg:col-span-4 flex items-center justify-center pt-8 lg:pt-0">
        <div 
          class="w-36 h-36 sm:w-44 sm:h-44 rounded-full flex items-center justify-center border shadow-2xl relative"
          style={`background-color: ${service.color}10; border-color: ${service.color}25; color: ${service.color};`}
        >
          <!-- Outer pulsing ring -->
          <span class="absolute inset-0 rounded-full animate-ping opacity-10" style={`background-color: ${service.color};`}></span>

          {service.icon === 'flame' && (
            <svg class="w-16 h-16 sm:w-20 sm:h-20 fill-current" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 5.523 4.477 10 10 10s10-4.477 10-10c0-5.523-4.477-10-10-10zm4.25 13.5h-8.5v-1.5h8.5v1.5zm0-2.5h-8.5v-1.5h8.5v1.5zm0-2.5h-8.5v-1.5h8.5v1.5z" />
            </svg>
          )}
          {service.icon === 'target' && (
            <svg class="w-16 h-16 sm:w-20 sm:h-20 stroke-current stroke-[1.5] fill-none" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="3" />
            </svg>
          )}
          {service.icon === 'code' && (
            <svg class="w-16 h-16 sm:w-20 sm:h-20 stroke-current stroke-[1.5] fill-none" viewBox="0 0 24 24">
              <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" />
            </svg>
          )}
          {service.icon === 'map-pin' && (
            <svg class="w-16 h-16 sm:w-20 sm:h-20 stroke-current stroke-[1.5] fill-none" viewBox="0 0 24 24">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
            </svg>
          )}
          {service.icon === 'trending-up' && (
            <svg class="w-16 h-16 sm:w-20 sm:h-20 stroke-current stroke-[1.5] fill-none" viewBox="0 0 24 24">
              <path d="M23 6l-9.5 9.5-5-5L1 18" />
            </svg>
          )}
          {service.icon === 'instagram' && (
            <svg class="w-16 h-16 sm:w-20 sm:h-20 stroke-current stroke-[1.5] fill-none" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" />
            </svg>
          )}
        </div>
      </div>

    </div>
  </div>
</section>
