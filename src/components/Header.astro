---
import { Phone, MessageCircle, ArrowRight, ChevronDown, CheckCircle, ShieldAlert } from 'lucide-astro';

// Import our databases to map links in the mega menu
import servicesData from '../data/services.json';
import industriesData from '../data/industries.json';
import citiesData from '../data/cities.json';

// Get top cities by region for the mega menu
const getTopCitiesByRegion = (region: string) => {
  return citiesData
    .filter(c => c.region === region)
    .sort((a, b) => parseInt(b.population.replace(/,/g, '')) - parseInt(a.population.replace(/,/g, '')))
    .slice(0, 8);
};

const northCities = getTopCitiesByRegion('North');
const southCities = getTopCitiesByRegion('South');
const eastCities = getTopCitiesByRegion('East');
const westCities = getTopCitiesByRegion('West');

// Automatic light/dark page detection
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
const isServiceDetail = pathname.startsWith('/services/') && pathname !== '/services' && pathname !== '/services/';
const isResearchLanding = pathname.includes('/research-reports');
const isUtsavLanding = pathname.includes('/bodhi-utsav');

// If it's NOT home, NOT service details, NOT research landing, and NOT utsav landing -> it's a light background page!
const isLight = !isHome && !isServiceDetail && !isResearchLanding && !isUtsavLanding;

const headerDefaultClass = isLight
  ? "fixed top-0 left-0 right-0 z-50 w-full transition-all duration-300 py-3.5 bg-white/90 backdrop-blur-lg border-neutral-mist/80 shadow-sm scrolled-header"
  : "fixed top-0 left-0 right-0 z-50 w-full transition-all duration-300 py-4 bg-transparent border-b border-transparent";

const wordmarkDefaultClass = isLight
  ? "font-display font-extrabold text-xl sm:text-2xl tracking-tight leading-none text-neutral-charcoal group-hover:text-primary-saffron transition-colors"
  : "font-display font-extrabold text-xl sm:text-2xl tracking-tight leading-none text-white group-hover:text-primary-saffron transition-colors";

const taglineDefaultClass = isLight
  ? "hidden sm:inline text-[9px] font-body font-bold text-neutral-stone normal-case tracking-widest mt-0.5 leading-none"
  : "hidden sm:inline text-[9px] font-body font-bold text-white/60 normal-case tracking-widest mt-0.5 leading-none";

const navDefaultClass = isLight
  ? "hidden xl:flex items-center gap-5 font-display font-bold text-[11px] normal-case tracking-wider text-neutral-charcoal"
  : "hidden xl:flex items-center gap-5 font-display font-bold text-[11px] normal-case tracking-wider text-white";

const phoneDefaultClass = isLight
  ? "flex items-center gap-1.5 font-mono text-[11px] font-bold text-neutral-charcoal hover:text-primary-saffron transition-colors"
  : "flex items-center gap-1.5 font-mono text-[11px] font-bold text-white hover:text-primary-saffron transition-colors";

const mobileBtnDefaultClass = isLight
  ? "xl:hidden p-2 rounded-xl text-neutral-charcoal hover:bg-neutral-cloud focus:outline-none group relative w-10 h-10 flex flex-col justify-center gap-1.5 items-center z-50"
  : "xl:hidden p-2 rounded-xl text-white hover:bg-white/10 focus:outline-none group relative w-10 h-10 flex flex-col justify-center gap-1.5 items-center z-50";
---

<header id="main-header" class={headerDefaultClass} data-is-light={isLight ? "true" : "false"}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      
      <!-- Brand Logo Section (Left) -->
      <a href="/" class="flex items-center gap-3 group focus:outline-none" aria-label="RoasBodhi Home">
        <!-- Leaf Logo Mark -->
        <svg class="w-10 h-10 transition-transform duration-300 group-hover:scale-105" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#FF6B2B" /> <!-- Saffron -->
              <stop offset="100%" stop-color="#F5A623" /> <!-- Gold -->
            </linearGradient>
          </defs>
          <path d="M20 2C20 2 34 16 34 26C34 32.6274 27.732 38 20 38C12.268 38 6 32.6274 6 26C6 16 20 2 20 2Z" fill="url(#logoGrad)" />
          <!-- Vein bars forming an upward graph representing ROAS growth -->
          <path d="M20 34V10" stroke="white" stroke-width="2.5" stroke-linecap="round" />
          <path d="M20 30L26 24" stroke="white" stroke-width="2" stroke-linecap="round" />
          <path d="M20 24L29 15" stroke="white" stroke-width="2" stroke-linecap="round" />
          <path d="M20 27L14 21" stroke="white" stroke-width="2" stroke-linecap="round" />
          <path d="M20 21L11 12" stroke="white" stroke-width="2" stroke-linecap="round" />
        </svg>
        <div class="flex flex-col">
          <span class={wordmarkDefaultClass} id="brand-wordmark">
            Roas<span class="text-primary-saffron">Bodhi</span><span class="text-[10px] font-semibold text-primary-gold align-super ml-0.5 opacity-80">™</span>
          </span>
          <span class={taglineDefaultClass} id="brand-tagline">
            Awakening Your Ad Returns
          </span>
        </div>
      </a>

      <!-- Desktop Navigation Menu (Center) -->
      <nav class={navDefaultClass} id="desktop-nav">
        
        <!-- Dropdown 1: Services (2-Column Grid) -->
        <div class="relative py-2 dropdown-container" data-dropdown="services">
          <button class="flex items-center gap-1 hover:text-primary-saffron transition-colors focus:outline-none py-1.5" aria-expanded="false" aria-haspopup="true">
            Services
            <ChevronDown class="w-3.5 h-3.5 transition-transform duration-200 chevron-icon" />
          </button>
          <div class="absolute left-1/2 -translate-x-1/2 top-full w-[760px] bg-white/95 backdrop-blur-xl text-neutral-charcoal rounded-3xl shadow-[0_24px_60px_rgba(0,0,0,0.08)] border border-neutral-mist/60 p-6 opacity-0 pointer-events-none transition-all duration-300 transform translate-y-2 z-50 dropdown-panel animate-dropdown">
            <div class="grid grid-cols-12 gap-6">
              
              <!-- Left Column: Service Lists (col-span-8) -->
              <div class="col-span-8 pr-4 border-r border-neutral-mist/40">
                <span class="text-[9px] font-display font-extrabold text-neutral-stone normal-case tracking-widest block mb-4">Our Core Capabilities</span>
                <div class="grid grid-cols-2 gap-x-4 gap-y-3">
                  {servicesData.map(service => (
                    <a href={`/services/${service.slug}/`} class="group flex items-start gap-3 p-2.5 rounded-2xl hover:bg-neutral-ghost transition-all duration-300">
                      <div class="w-10 h-10 rounded-xl bg-primary-saffron/10 border border-primary-saffron/20 flex items-center justify-center text-primary-saffron flex-shrink-0 transition-all duration-300 group-hover:bg-primary-saffron group-hover:text-white group-hover:scale-105">
                        {service.icon === 'flame' && (
                          <svg class="w-4.5 h-4.5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2C6.477 2 2 6.477 2 12c0 5.523 4.477 10 10 10s10-4.477 10-10c0-5.523-4.477-10-10-10zm4.25 13.5h-8.5v-1.5h8.5v1.5zm0-2.5h-8.5v-1.5h8.5v1.5zm0-2.5h-8.5v-1.5h8.5v1.5z" />
                          </svg>
                        )}
                        {service.icon === 'target' && (
                          <svg class="w-4.5 h-4.5 stroke-current stroke-2" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="12" cy="12" r="10" />
                            <circle cx="12" cy="12" r="3" />
                          </svg>
                        )}
                        {service.icon === 'code' && (
                          <svg class="w-4.5 h-4.5 stroke-current stroke-2" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" />
                          </svg>
                        )}
                        {service.icon === 'map-pin' && (
                          <svg class="w-4.5 h-4.5 stroke-current stroke-2" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                          </svg>
                        )}
                        {service.icon === 'trending-up' && (
                          <svg class="w-4.5 h-4.5 stroke-current stroke-2" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M23 6l-9.5 9.5-5-5L1 18" />
                          </svg>
                        )}
                        {service.icon === 'instagram' && (
                          <svg class="w-4.5 h-4.5 stroke-current stroke-2" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" />
                          </svg>
                        )}
                        {service.icon === 'search' && (
                          <svg class="w-4.5 h-4.5 stroke-current stroke-2" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                          </svg>
                        )}
                      </div>
                      <div class="flex flex-col">
                        <span class="font-display font-extrabold text-neutral-dark text-xs tracking-wide group-hover:text-primary-saffron transition-colors">
                          {service.name}
                        </span>
                        <span class="text-[10px] text-neutral-stone font-semibold mt-0.5 leading-snug">
                          {service.short_description}
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
              
              <!-- Right Column: Featured Callout (col-span-4) -->
              <div class="col-span-4 flex flex-col justify-between">
                <div class="bg-gradient-to-br from-primary-saffron/5 to-primary-gold/5 border border-primary-saffron/10 rounded-2xl p-5 flex flex-col gap-3">
                  <span class="w-8 h-8 rounded-lg bg-primary-saffron/10 flex items-center justify-center text-primary-saffron text-sm font-semibold">🔱</span>
                  <div>
                    <h5 class="font-display font-extrabold text-xs text-neutral-dark tracking-wide normal-case">Free ROAS Audit</h5>
                    <p class="font-body text-[10px] text-neutral-stone font-semibold leading-relaxed mt-1">
                      Get a complimentary competitor analysis and conversion path roadmap for your local business.
                    </p>
                  </div>
                  <a href="/contact/" class="group/btn inline-flex items-center gap-1 text-[10px] font-display font-extrabold text-primary-saffron normal-case tracking-wider">
                    Claim Free Audit <ArrowRight class="w-3.5 h-3.5 transition-transform duration-200 group-hover/btn:translate-x-1" />
                  </a>
                </div>
                
                <a href="/pricing/" class="font-display font-extrabold text-[10px] text-neutral-stone hover:text-primary-saffron transition-colors flex items-center justify-center gap-1 border-t border-neutral-mist/50 pt-4 mt-4 normal-case tracking-wider">
                  View Plans & Pricing <ArrowRight class="w-3.5 h-3.5" />
                </a>
              </div>

            </div>
          </div>
        </div>

        <!-- Dropdown 2: Industries (3-Column Grid) -->
        <div class="relative py-2 dropdown-container" data-dropdown="industries">
          <button class="flex items-center gap-1 hover:text-primary-saffron transition-colors focus:outline-none py-1.5" aria-expanded="false" aria-haspopup="true">
            Industries
            <ChevronDown class="w-3.5 h-3.5 transition-transform duration-200 chevron-icon" />
          </button>
          <div class="absolute left-1/2 -translate-x-1/2 top-full w-[540px] bg-white text-neutral-charcoal rounded-2xl shadow-card-hover border border-neutral-mist p-5 opacity-0 pointer-events-none transition-all duration-200 transform translate-y-2 z-50 dropdown-panel">
            <div class="grid grid-cols-3 gap-3">
              {industriesData.map(ind => (
                <a href={`/results/?industry=${ind.slug}`} class="flex items-center gap-2 p-2 rounded-lg hover:bg-neutral-ghost transition-colors">
                  <span class="text-xs text-neutral-charcoal font-semibold normal-case leading-none hover:text-primary-saffron">
                    {ind.name.replace(" & Legal", "").replace(" Developers", "").replace(" Showrooms", "").replace(" Clinics", "")}
                  </span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Dropdown 3: Locations (4-Column Mega Menu) -->
        <div class="relative py-2 dropdown-container" data-dropdown="locations">
          <button class="flex items-center gap-1 hover:text-primary-saffron transition-colors focus:outline-none py-1.5" aria-expanded="false" aria-haspopup="true">
            Locations
            <ChevronDown class="w-3.5 h-3.5 transition-transform duration-200 chevron-icon" />
          </button>
          <div class="absolute -left-48 top-full w-[780px] bg-white text-neutral-charcoal rounded-2xl shadow-card-hover border border-neutral-mist p-6 opacity-0 pointer-events-none transition-all duration-200 transform translate-y-2 z-50 dropdown-panel">
            <div class="grid grid-cols-4 gap-6">
              <!-- North -->
              <div class="flex flex-col gap-2.5">
                <span class="text-[10px] font-display font-extrabold text-primary-saffron tracking-widest border-b border-neutral-mist pb-1.5">North</span>
                <ul class="flex flex-col gap-2">
                  {northCities.map(city => (
                    <li>
                      <a href={`/meta-ads-agency-${city.slug}/`} class="text-[11px] text-neutral-stone hover:text-primary-saffron font-medium normal-case transition-colors">
                        {city.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              
              <!-- South -->
              <div class="flex flex-col gap-2.5">
                <span class="text-[10px] font-display font-extrabold text-primary-saffron tracking-widest border-b border-neutral-mist pb-1.5">South</span>
                <ul class="flex flex-col gap-2">
                  {southCities.map(city => (
                    <li>
                      <a href={`/meta-ads-agency-${city.slug}/`} class="text-[11px] text-neutral-stone hover:text-primary-saffron font-medium normal-case transition-colors">
                        {city.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>

              <!-- East -->
              <div class="flex flex-col gap-2.5">
                <span class="text-[10px] font-display font-extrabold text-primary-saffron tracking-widest border-b border-neutral-mist pb-1.5">East</span>
                <ul class="flex flex-col gap-2">
                  {eastCities.map(city => (
                    <li>
                      <a href={`/meta-ads-agency-${city.slug}/`} class="text-[11px] text-neutral-stone hover:text-primary-saffron font-medium normal-case transition-colors">
                        {city.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>

              <!-- West -->
              <div class="flex flex-col gap-2.5">
                <span class="text-[10px] font-display font-extrabold text-primary-saffron tracking-widest border-b border-neutral-mist pb-1.5">West</span>
                <ul class="flex flex-col gap-2">
                  {westCities.map(city => (
                    <li>
                      <a href={`/meta-ads-agency-${city.slug}/`} class="text-[11px] text-neutral-stone hover:text-primary-saffron font-medium normal-case transition-colors">
                        {city.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
            
            <div class="border-t border-neutral-mist/50 mt-6 pt-4 text-center">
              <a href="/contact/" class="font-display font-extrabold text-[10px] text-primary-saffron hover:underline flex items-center justify-center gap-1">
                View All 180+ Indian Cities Directory <ArrowRight class="w-3.5 h-3.5" />
              </a>
            </div>
          </div>
        </div>

        <a href="/results/" class="hover:text-primary-saffron transition-colors py-1.5">Results</a>
        <a href="/blog/" class="hover:text-primary-saffron transition-colors py-1.5">Blog</a>
        <a href="/pricing/" class="hover:text-primary-saffron transition-colors py-1.5">Pricing</a>
      </nav>

      <!-- Desktop Call Actions & Badge (Right) -->
      <div class="hidden xl:flex flex-col items-end gap-1.5 select-none" id="desktop-ctas">
        <div class="flex items-center gap-4">
          <!-- Direct Phone -->
          <a href="tel:+9082543992" class={phoneDefaultClass} aria-label="Call RoasBodhi Support">
            <Phone class="w-3.5 h-3.5 text-primary-saffron" />
            +91 90825 43992
          </a>
          
          <!-- Direct WhatsApp -->
          <a href="https://wa.me/9082543992?text=Namaste%20RoasBodhi%E2%84%A2!%20I%27d%20like%20to%20consult%20on%20web%20design%20and%20ads%20for%20my%20business." target="_blank" rel="noopener noreferrer" class="flex items-center justify-center p-1.5 rounded-full bg-emerald-50 text-emerald-600 hover:bg-emerald-100 transition-colors" aria-label="Chat on WhatsApp">
            <MessageCircle class="w-4.5 h-4.5 fill-emerald-600" />
          </a>

          <!-- Primary Button with 4s pulse loops -->
          <a href="/contact/" class="px-5 py-2.5 font-display font-extrabold text-[10px] normal-case tracking-wider text-white rounded-full bg-gradient-to-r from-primary-saffron to-primary-gold hover:shadow-button-saffron hover:-translate-y-0.5 transition-all duration-300 flex items-center gap-1 relative overflow-hidden animate-pulse-glow" id="nav-primary-cta">
            <span>Free ROAS Audit</span>
            <ArrowRight class="w-3.5 h-3.5" />
          </a>
        </div>
        
        <!-- Trust badge indicator below buttons -->
        <div class="flex items-center gap-3 text-[9px] font-body font-semibold text-neutral-stone mr-2">
          <span class="flex items-center gap-1"><CheckCircle class="w-3 h-3 text-secondary-emerald" /> SSL Secured</span>
          <span class="text-neutral-mist">|</span>
          <span class="flex items-center gap-1"><CheckCircle class="w-3 h-3 text-secondary-emerald" /> ⭐ 4.9/5 Rating</span>
        </div>
      </div>

      <!-- Mobile Hamburger Button Menu Toggle -->
      <button id="mobile-menu-btn" class={mobileBtnDefaultClass} aria-label="Toggle Navigation Menu" aria-expanded="false">
        <span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center" id="ham-line1"></span>
        <span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center" id="ham-line2"></span>
        <span class="w-6 h-0.5 bg-current transition-all duration-300 origin-center" id="ham-line3"></span>
      </button>

    </div>
  </div>

  <!-- Mobile Drawer Menu (Full screen Slide overlay) -->
  <div id="mobile-drawer" class="fixed inset-0 z-40 bg-primary-indigo/98 backdrop-blur-lg text-white flex flex-col p-6 transition-transform duration-300 translate-x-full xl:hidden">
    
    <!-- Logo inside mobile menu drawer -->
    <div class="flex items-center gap-3 select-none mb-10 mt-4">
      <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none">
        <path d="M20 2C20 2 34 16 34 26C34 32.6274 27.732 38 20 38C12.268 38 6 32.6274 6 26C6 16 20 2 20 2Z" fill="url(#logoGrad)" />
        <path d="M20 34V10" stroke="white" stroke-width="2.5" stroke-linecap="round" />
        <path d="M20 30L26 24" stroke="white" stroke-width="2" stroke-linecap="round" />
        <path d="M20 24L29 15" stroke="white" stroke-width="2" stroke-linecap="round" />
      </svg>
      <span class="font-display font-extrabold text-xl tracking-tight leading-none">
        Roas<span class="text-primary-saffron">Bodhi</span>
      </span>
    </div>

    <!-- Stacked Navigation Links with large targets -->
    <div class="flex flex-col gap-6 font-display font-extrabold text-lg flex-grow overflow-y-auto mb-8 pr-2">
      <a href="/" class="mobile-nav-link border-b border-white/10 pb-3 hover:text-primary-saffron transition-colors">Home</a>
      
      <!-- Collapsible Services Accordion -->
      <div class="flex flex-col border-b border-white/10 pb-3">
        <button id="mobile-services-toggle" class="flex items-center justify-between text-left focus:outline-none w-full">
          <span>Services</span>
          <ChevronDown class="w-5 h-5 transition-transform duration-200" id="mobile-services-arrow" />
        </button>
        <div id="mobile-services-list" class="flex flex-col gap-3 pl-4 overflow-hidden max-h-0 transition-all duration-300 mt-3 font-body font-semibold text-sm text-white/80">
          {servicesData.map(service => (
            <a href={`/services/${service.slug}/`} class="hover:text-primary-saffron transition-colors">{service.name}</a>
          ))}
        </div>
      </div>

      <!-- Collapsible Industries Accordion -->
      <div class="flex flex-col border-b border-white/10 pb-3">
        <button id="mobile-industries-toggle" class="flex items-center justify-between text-left focus:outline-none w-full">
          <span>Industries</span>
          <ChevronDown class="w-5 h-5 transition-transform duration-200" id="mobile-industries-arrow" />
        </button>
        <div id="mobile-industries-list" class="flex flex-col gap-3 pl-4 overflow-hidden max-h-0 transition-all duration-300 mt-3 font-body font-semibold text-sm text-white/80">
          {industriesData.map(ind => (
            <a href={`/results/?industry=${ind.slug}`} class="hover:text-primary-saffron transition-colors">{ind.name}</a>
          ))}
        </div>
      </div>

      <a href="/results/" class="mobile-nav-link border-b border-white/10 pb-3 hover:text-primary-saffron transition-colors">Results</a>
      <a href="/blog/" class="mobile-nav-link border-b border-white/10 pb-3 hover:text-primary-saffron transition-colors">Blog</a>
      <a href="/pricing/" class="mobile-nav-link border-b border-white/10 pb-3 hover:text-primary-saffron transition-colors">Pricing</a>
      <a href="/about/" class="mobile-nav-link border-b border-white/10 pb-3 hover:text-primary-saffron transition-colors">About Us</a>
      <a href="/contact/" class="mobile-nav-link border-b border-white/10 pb-3 hover:text-primary-saffron transition-colors">Contact</a>
    </div>

    <!-- Mobile Drawer CTA Actions -->
    <div class="mt-auto flex flex-col gap-4">
      <a href="tel:+9082543992" class="flex items-center justify-center gap-2 py-3.5 border border-white/20 hover:border-white/40 rounded-xl font-body font-bold text-sm transition-colors">
        <Phone class="w-4 h-4 text-primary-saffron" />
        Call +91 90825 43992
      </a>
      <a href="https://wa.me/9082543992?text=Namaste%20RoasBodhi%E2%84%A2!%20I%27d%20like%20to%20consult%20on%20web%20design%20and%20ads%20for%20my%20business." target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 py-3.5 bg-emerald-600 hover:bg-emerald-700 rounded-xl font-body font-bold text-sm transition-colors">
        <MessageCircle class="w-4.5 h-4.5 fill-white" />
        WhatsApp Chat
      </a>
      <a href="/contact/" class="py-4 bg-gradient-to-r from-primary-saffron to-primary-gold hover:shadow-button-saffron rounded-xl font-display font-extrabold text-center text-sm tracking-wider normal-case">
        Get Free ROAS Audit →
      </a>
    </div>

  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('main-header')!;
    const wordmark = document.getElementById('brand-wordmark')!;
    const tagline = document.getElementById('brand-tagline')!;
    const desktopNav = document.getElementById('desktop-nav')!;
    const phoneLink = document.querySelector('#desktop-ctas a[href^="tel"]') as HTMLAnchorElement;
    const mobileMenuBtn = document.getElementById('mobile-menu-btn')!;
    
    const isLightPage = header.getAttribute('data-is-light') === 'true';
    
    // Header Frosted glass color changes on scroll
    const handleScroll = () => {
      if (window.scrollY > 10 || isLightPage) {
        header.classList.remove('bg-transparent', 'border-transparent', 'py-4');
        header.classList.add('bg-white/90', 'backdrop-blur-lg', 'border-neutral-mist/80', 'py-3.5', 'shadow-sm');
        
        // Ensure text contrast is sharp when white background is active
        wordmark.classList.remove('text-white');
        wordmark.classList.add('text-neutral-charcoal');
        tagline.classList.remove('text-white/60');
        tagline.classList.add('text-neutral-stone');
        desktopNav.classList.remove('text-white');
        desktopNav.classList.add('text-neutral-charcoal');
        if (phoneLink) {
          phoneLink.classList.remove('text-white');
          phoneLink.classList.add('text-neutral-charcoal');
        }
        if (mobileMenuBtn) {
          mobileMenuBtn.classList.remove('text-white', 'hover:bg-white/10');
          mobileMenuBtn.classList.add('text-neutral-charcoal', 'hover:bg-neutral-cloud');
        }
      } else {
        header.classList.add('bg-transparent', 'border-transparent', 'py-4');
        header.classList.remove('bg-white/90', 'backdrop-blur-lg', 'border-neutral-mist/80', 'py-3.5', 'shadow-sm');
        
        // Restore text contrast for dark background on scroll exit
        wordmark.classList.add('text-white');
        wordmark.classList.remove('text-neutral-charcoal');
        tagline.classList.add('text-white/60');
        tagline.classList.remove('text-neutral-stone');
        desktopNav.classList.add('text-white');
        desktopNav.classList.remove('text-neutral-charcoal');
        if (phoneLink) {
          phoneLink.classList.add('text-white');
          phoneLink.classList.remove('text-neutral-charcoal');
        }
        if (mobileMenuBtn) {
          mobileMenuBtn.classList.add('text-white', 'hover:bg-white/10');
          mobileMenuBtn.classList.remove('text-neutral-charcoal', 'hover:bg-neutral-cloud');
        }
      }
    };
    window.addEventListener('scroll', handleScroll);
    handleScroll();

    // Handle Dropdown open/close timing delay on desktop
    const dropdownContainers = document.querySelectorAll('.dropdown-container');
    dropdownContainers.forEach(container => {
      const trigger = container.querySelector('button')!;
      const panel = container.querySelector('.dropdown-panel')!;
      const chevron = container.querySelector('.chevron-icon')!;
      let closeTimeout: number | undefined;

      const openDropdown = () => {
        clearTimeout(closeTimeout);
        trigger.setAttribute('aria-expanded', 'true');
        panel.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-2');
        panel.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
        chevron.classList.add('rotate-180');
      };

      const closeDropdown = () => {
        closeTimeout = window.setTimeout(() => {
          trigger.setAttribute('aria-expanded', 'false');
          panel.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
          panel.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
          chevron.classList.remove('rotate-180');
        }, 150); // 150ms hover exit delay
      };

      container.addEventListener('mouseenter', openDropdown);
      container.addEventListener('mouseleave', closeDropdown);
      
      // Accessibility focus handlers
      trigger.addEventListener('focus', openDropdown);
      container.addEventListener('focusout', (e) => {
        if (!container.contains(e.relatedTarget as Node)) {
          closeDropdown();
        }
      });
    });

    // Mobile Hamburger Hamburger to X animation trigger
    const menuBtn = document.getElementById('mobile-menu-btn')!;
    const drawer = document.getElementById('mobile-drawer')!;
    const line1 = document.getElementById('ham-line1')!;
    const line2 = document.getElementById('ham-line2')!;
    const line3 = document.getElementById('ham-line3')!;

    menuBtn.addEventListener('click', () => {
      const isOpen = drawer.classList.contains('translate-x-0');
      if (isOpen) {
        // Close menu
        drawer.classList.remove('translate-x-0');
        drawer.classList.add('translate-x-full');
        menuBtn.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('overflow-hidden');
        
        // Reset lines
        line1.classList.remove('rotate-45', 'translate-y-2');
        line2.classList.remove('opacity-0');
        line3.classList.remove('-rotate-45', '-translate-y-2');
      } else {
        // Open menu
        drawer.classList.remove('translate-x-full');
        drawer.classList.add('translate-x-0');
        menuBtn.setAttribute('aria-expanded', 'true');
        document.body.classList.add('overflow-hidden');
        
        // Animate to X
        line1.classList.add('rotate-45', 'translate-y-2');
        line2.classList.add('opacity-0');
        line3.classList.add('-rotate-45', '-translate-y-2');
      }
    });

    // Accordion expand triggers inside mobile drawer
    const setupAccordion = (toggleId: string, listId: string, arrowId: string) => {
      const toggle = document.getElementById(toggleId)!;
      const list = document.getElementById(listId)!;
      const arrow = document.getElementById(arrowId)!;

      toggle.addEventListener('click', () => {
        const isExpanded = list.style.maxHeight && list.style.maxHeight !== '0px';
        if (isExpanded) {
          list.style.maxHeight = '0px';
          arrow.classList.remove('rotate-180');
        } else {
          list.style.maxHeight = `${list.scrollHeight}px`;
          arrow.classList.add('rotate-180');
        }
      });
    };

    setupAccordion('mobile-services-toggle', 'mobile-services-list', 'mobile-services-arrow');
    setupAccordion('mobile-industries-toggle', 'mobile-industries-list', 'mobile-industries-arrow');
  });
</script>
