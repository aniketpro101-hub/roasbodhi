---
import { ArrowUp } from 'lucide-astro';
---

<button 
  id="global-scroll-to-top" 
  class="fixed bottom-36 right-6 z-40 w-11 h-11 bg-primary-indigo hover:bg-neutral-dark text-white rounded-full shadow-md flex items-center justify-center translate-y-12 opacity-0 pointer-events-none transition-all duration-300 group border border-white/10"
  aria-label="Scroll back to top of page"
>
  <ArrowUp class="w-5 h-5 transition-transform duration-200 group-hover:-translate-y-0.5" />
</button>

<script>
  const scrollTopBtn = document.getElementById('global-scroll-to-top');

  if (scrollTopBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        scrollTopBtn.classList.remove('translate-y-12', 'opacity-0', 'pointer-events-none');
        scrollTopBtn.classList.add('translate-y-0', 'opacity-100');
      } else {
        scrollTopBtn.classList.remove('translate-y-0', 'opacity-100');
        scrollTopBtn.classList.add('translate-y-12', 'opacity-0', 'pointer-events-none');
      }
    });

    scrollTopBtn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }
</script>
