---
import { MapPin, ArrowRight, ArrowUpRight } from 'lucide-astro';

interface Props {
  caseStudy: {
    id: string;
    title: string;
    client_type: string;
    industry: string;
    city: string;
    state: string;
    services_used: string[];
    duration: string;
    results: {
      roas: string;
      leads_per_month: string;
      cpl_before: string;
      cpl_after: string;
      revenue_increase: string;
    };
    featured_image: string;
  };
}

const { caseStudy } = Astro.props;

// Accent gradients based on industry color schemes
const gradients = {
  'real-estate': 'from-blue-600 to-indigo-900',
  'jewellery': 'from-amber-500 to-amber-800',
  'dental-clinics': 'from-emerald-600 to-teal-900',
  'manufacturing': 'from-slate-600 to-zinc-800',
  'packers-movers': 'from-orange-600 to-red-900',
  'restaurant': 'from-rose-600 to-rose-900',
  'education': 'from-purple-600 to-violet-900'
};

const curGradient = gradients[caseStudy.industry as keyof typeof gradients] || 'from-primary-saffron to-primary-gold';
---

<div 
  class="bg-white rounded-2xl overflow-hidden shadow-[0_4px_20px_rgba(30,27,75,0.06)] hover:-translate-y-1.5 hover:shadow-[0_20px_60px_rgba(30,27,75,0.12)] transition-all duration-300 flex flex-col group border border-neutral-mist/50"
  data-industry={caseStudy.industry}
>
  
  <!-- TOP IMAGE AREA (200px height) -->
  <div class="h-[200px] w-full relative bg-neutral-dark overflow-hidden select-none">
    
    <!-- Fallback Gradient Background -->
    <div class={`absolute inset-0 bg-gradient-to-br ${curGradient} opacity-60 z-0`}></div>
    
    <!-- Subtle tech circles layout grid -->
    <div class="absolute inset-0 bg-[radial-gradient(#ffffff08_1px,transparent_1px)] bg-[size:16px_16px] z-0"></div>

    <!-- Image overlay if exists, else placeholder -->
    {caseStudy.featured_image ? (
      <img 
        src={caseStudy.featured_image} 
        alt={caseStudy.title} 
        class="w-full h-full object-cover relative z-10 opacity-70 group-hover:scale-105 transition-transform duration-500" 
        onerror="this.style.display='none'"
      />
    ) : null}

    <!-- Dark gradient overlay bottom-50% -->
    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-neutral-dark/80 to-transparent z-20"></div>

    <!-- Platform Badges (bottom-left) -->
    <div class="absolute bottom-4 left-4 z-30 flex flex-wrap gap-1.5">
      {caseStudy.services_used.map(service => (
        <span class="px-2 py-0.5 rounded bg-white/10 border border-white/20 text-[8px] font-display font-extrabold uppercase tracking-widest text-white backdrop-blur-sm">
          {service}
        </span>
      ))}
    </div>

    <!-- Result Badges (floating on image) -->
    <!-- Top-Right: ROAS -->
    <div class="absolute top-4 right-4 z-30 px-3 py-1 rounded-full bg-secondary-emerald text-white text-[10px] font-display font-extrabold uppercase tracking-widest shadow-md flex items-center gap-1 animate-float">
      <span>🚀 {caseStudy.results.roas} ROAS</span>
    </div>

    <!-- Top-Left: Revenue or Leads -->
    <div 
      class="absolute top-4 left-4 z-30 px-3 py-1 rounded-full bg-primary-gold text-white text-[10px] font-display font-extrabold uppercase tracking-widest shadow-md flex items-center gap-1 animate-float"
      style="animation-delay: 1.5s;"
    >
      <span>📈 {caseStudy.results.revenue_increase || caseStudy.results.leads_per_month}</span>
    </div>

  </div>

  <!-- CONTENT AREA -->
  <div class="p-6 flex flex-col flex-grow select-none">
    
    <!-- Meta items -->
    <div class="flex items-center justify-between text-[10px] font-display font-extrabold uppercase tracking-wider text-neutral-stone mb-2.5">
      <span class="px-2 py-0.5 rounded bg-neutral-ghost border border-neutral-mist text-neutral-charcoal">
        {caseStudy.industry}
      </span>
      <span class="flex items-center gap-1">
        <MapPin class="w-3 h-3 text-primary-saffron" />
        {caseStudy.city}, {caseStudy.state}
      </span>
    </div>

    <h3 class="font-display font-extrabold text-neutral-dark text-base group-hover:text-primary-saffron transition-colors leading-snug text-left mb-2">
      <a href={`/results/${caseStudy.slug}/`}>{caseStudy.title}</a>
    </h3>
    
    <span class="text-[11px] font-body font-semibold text-neutral-stone text-left block mb-4">
      Niche: {caseStudy.client_type}
    </span>

    <div class="border-t border-neutral-mist/50 my-2"></div>

    <!-- METRICS TABLE -->
    <div class="flex flex-col gap-2.5 py-4 text-xs font-body font-semibold text-neutral-charcoal">
      <!-- CPL -->
      <div class="flex justify-between items-center">
        <span class="text-neutral-stone font-medium">Cost Per Lead (CPL):</span>
        <span class="flex items-center gap-1.5 font-mono">
          <span class="line-through text-neutral-stone/60">{caseStudy.results.cpl_before}</span>
          <span class="text-neutral-mist">→</span>
          <span class="text-secondary-emerald font-extrabold">{caseStudy.results.cpl_after}</span>
        </span>
      </div>

      <!-- Leads -->
      <div class="flex justify-between items-center">
        <span class="text-neutral-stone font-medium">Monthly Leads:</span>
        <span class="flex items-center gap-1.5 font-mono">
          <span class="text-neutral-stone/60">Low Baseline</span>
          <span class="text-neutral-mist">→</span>
          <span class="text-secondary-emerald font-extrabold">{caseStudy.results.leads_per_month}</span>
        </span>
      </div>

      <!-- ROAS -->
      <div class="flex justify-between items-center">
        <span class="text-neutral-stone font-medium">Ad Return ROAS:</span>
        <span class="flex items-center gap-1.5 font-mono">
          <span class="line-through text-neutral-stone/60">1.2X</span>
          <span class="text-neutral-mist">→</span>
          <span class="text-secondary-emerald font-extrabold">{caseStudy.results.roas}</span>
        </span>
      </div>

      <!-- Timeline -->
      <div class="flex justify-between items-center border-t border-neutral-mist/30 pt-2.5 mt-1 text-[10px] text-neutral-stone uppercase tracking-wider">
        <span>Timeline:</span>
        <span class="font-bold text-neutral-charcoal">Results in {caseStudy.duration}</span>
      </div>
    </div>

    <!-- CARD FOOTER -->
    <div class="mt-auto border-t border-neutral-mist/50 pt-4 flex items-center justify-end">
      <a 
        href={`/results/${caseStudy.slug}/`} 
        class="font-display font-extrabold text-[10px] text-primary-saffron hover:underline uppercase tracking-wider flex items-center gap-1"
      >
        <span>Read Full Case Study</span>
        <ArrowRight class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" />
      </a>
    </div>

  </div>

</div>
