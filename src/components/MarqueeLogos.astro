---
interface Props {
  logos?: { name: string; image: string }[];
  speed?: number; // duration in seconds
}

// Default logos representing top brands
const defaultLogos = [
  { name: "Meta Business", image: "https://upload.wikimedia.org/wikipedia/commons/7/7b/Meta_Platforms_Inc._logo.svg" },
  { name: "Google Maps", image: "https://upload.wikimedia.org/wikipedia/commons/a/a9/Google_Maps_icon_%282020%29.svg" },
  { name: "Razorpay", image: "https://upload.wikimedia.org/wikipedia/commons/8/89/Razorpay_logo.svg" },
  { name: "Cloudflare", image: "https://upload.wikimedia.org/wikipedia/commons/9/94/Cloudflare_Logo.svg" },
  { name: "Shopify Partners", image: "https://upload.wikimedia.org/wikipedia/commons/0/0e/Shopify_logo_2018.svg" },
  { name: "Facebook Ads", image: "https://upload.wikimedia.org/wikipedia/commons/0/51/Facebook_f_logo_%282019%29.svg" }
];

const { logos = defaultLogos, speed = 25 } = Astro.props;

// Duplicate array to enable seamless marquee looping
const doubledLogos = [...logos, ...logos, ...logos];
---

<div class="relative w-full overflow-hidden select-none py-10 bg-white">
  
  <!-- Left/Right Masking Gradient (Fade edges) -->
  <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
  <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

  <!-- Row 1: Left to Right scrolling -->
  <div class="flex gap-16 items-center w-max animate-marquee hover:[animation-play-state:paused] cursor-pointer">
    {doubledLogos.map((logo) => (
      <div class="flex items-center justify-center h-12 w-40 grayscale opacity-45 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
        <span class="font-display font-extrabold text-sm text-neutral-stone lowercase italic tracking-wide">{logo.name}</span>
      </div>
    ))}
  </div>

  <!-- Space between rows -->
  <div class="h-8"></div>

  <!-- Row 2: Right to Left scrolling -->
  <div class="flex gap-16 items-center w-max animate-marquee-reverse hover:[animation-play-state:paused] cursor-pointer">
    {doubledLogos.map((logo) => (
      <div class="flex items-center justify-center h-12 w-40 grayscale opacity-45 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
        <span class="font-display font-extrabold text-sm text-neutral-stone lowercase italic tracking-wide">{logo.name}</span>
      </div>
    ))}
  </div>

</div>

<style define:vars={{ speed: `${speed}s` }}>
  /* Scope speed variables dynamically for pure CSS infinite scroll marquee */
  .animate-marquee {
    animation: marquee var(--speed) linear infinite;
  }
  .animate-marquee-reverse {
    animation: marquee-reverse var(--speed) linear infinite;
  }
</style>
