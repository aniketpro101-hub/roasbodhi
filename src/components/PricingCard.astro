---
import { Check, X, ShieldCheck } from 'lucide-astro';

interface Props {
  plan: {
    id: string;
    name: string;
    hindi: string;
    meaning: string;
    price: string;
    period: string;
    popular?: boolean;
    description: string;
    best_for?: string;
    features: {
      text: string;
      included: boolean;
      emphasis?: boolean;
    }[];
  };
  serviceName: string;
}

const { plan, serviceName } = Astro.props;

// Compile WhatsApp prefilled message parameter
const whatsappMsg = `Namaste RoasBodhi™! I'd like to subscribe to the ${plan.name} (${plan.hindi}) plan for ${serviceName}.`;
const whatsappUrl = `https://wa.me/919082543992?text=${encodeURIComponent(whatsappMsg)}`;
---

<div 
  class={`relative flex flex-col transition-all duration-300 w-full select-none ${
    plan.popular 
      ? 'bg-primary-indigo text-white border-2 border-primary-gold/50 rounded-3xl p-8 shadow-[0_30px_80px_rgba(30,27,75,0.30)] md:scale-105 z-10' 
      : 'bg-white text-neutral-charcoal border border-neutral-mist rounded-3xl p-8 shadow-sm hover:shadow-card-hover z-0'
  }`}
>
  
  <!-- POPULAR BADGE OVERLAP -->
  {plan.popular && (
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-primary-gold text-primary-indigo font-display font-extrabold text-[10px] uppercase tracking-widest px-4 py-1.5 rounded-full shadow-md whitespace-nowrap border border-white/20">
      ⭐ Most Popular
    </div>
  )}

  <!-- CARD HEADER -->
  <div class="flex flex-col gap-1.5 items-start text-left">
    <div class="flex items-center justify-between w-full">
      <span class={`font-mono font-extrabold text-lg sm:text-xl uppercase tracking-wider ${
        plan.popular ? 'text-primary-gold' : 'text-primary-saffron'
      }`}>
        {plan.hindi} <span class="text-xs font-sans tracking-wide">({plan.name})</span>
      </span>
      {plan.best_for && (
        <span class={`px-2.5 py-0.5 rounded-full text-[9px] font-display font-extrabold uppercase tracking-wider ${
          plan.popular ? 'bg-white/10 text-white' : 'bg-primary-saffron/10 text-primary-saffron'
        }`}>
          {plan.best_for}
        </span>
      )}
    </div>
    <span class={`font-body font-semibold italic text-xs ${plan.popular ? 'text-white/60' : 'text-neutral-stone'}`}>
      ({plan.meaning})
    </span>
  </div>

  <p class={`font-body text-xs mt-3 leading-relaxed text-left ${plan.popular ? 'text-white/70' : 'text-neutral-charcoal/80'}`}>
    {plan.description}
  </p>

  <div class="border-t border-neutral-mist/20 my-5"></div>

  <!-- PRICING BOX -->
  <div class="flex flex-col items-start gap-1 select-none text-left">
    <div class="flex items-baseline">
      <span class="font-mono text-3xl sm:text-4xl font-extrabold tracking-tight">
        {plan.price}
      </span>
      <span class={`font-body text-xs font-semibold ml-1.5 ${plan.popular ? 'text-white/65' : 'text-neutral-stone'}`}>
        {plan.period}
      </span>
    </div>
    <span class="text-[9px] font-display font-extrabold text-secondary-emerald uppercase tracking-widest mt-1">
      🛡️ Pay-After-Seeing active
    </span>
  </div>

  <div class="border-t border-neutral-mist/20 my-5"></div>

  <!-- FEATURES LIST -->
  <ul class="flex flex-col gap-3 text-left flex-grow select-none">
    {plan.features.map(feat => (
      <li class={`flex items-start gap-2.5 text-xs font-body leading-relaxed ${
        !feat.included ? 'opacity-40' : ''
      }`}>
        {feat.included ? (
          <div class="w-4 h-4 rounded-full bg-secondary-emerald text-white flex items-center justify-center flex-shrink-0 mt-0.5">
            <Check class="w-2.5 h-2.5 stroke-[3]" />
          </div>
        ) : (
          <div class="w-4 h-4 rounded-full bg-neutral-stone/20 text-neutral-stone flex items-center justify-center flex-shrink-0 mt-0.5">
            <X class="w-2.5 h-2.5 stroke-[3]" />
          </div>
        )}
        <span class={`${feat.emphasis ? 'font-bold' : 'font-medium'}`}>
          {feat.text}
        </span>
      </li>
    ))}
  </ul>

  <div class="border-t border-neutral-mist/20 my-6"></div>

  <!-- CTA BUTTON -->
  <a 
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class={`w-full py-4 font-display font-extrabold text-xs uppercase tracking-wider rounded-xl text-center transition-all duration-300 shadow-sm ${
      plan.popular
        ? 'bg-gradient-to-r from-primary-saffron to-primary-gold hover:shadow-button-saffron hover:-translate-y-0.5 text-white'
        : 'bg-transparent border border-primary-saffron text-primary-saffron hover:bg-primary-saffron hover:text-white'
    }`}
  >
    Subscribe Plan
  </a>

  <!-- Guarantee micro-text -->
  <p class={`text-[9px] font-body text-center font-bold tracking-wider uppercase mt-4 flex items-center justify-center gap-1 leading-none ${
    plan.popular ? 'text-white/60' : 'text-neutral-stone'
  }`}>
    <ShieldCheck class="w-3.5 h-3.5 text-secondary-emerald" />
    <span>100% Refund Before Launch</span>
  </p>

</div>
