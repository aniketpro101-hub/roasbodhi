---
import { MessageCircle } from 'lucide-astro';

interface Props {
  phone?: string;
  text?: string;
}

const { 
  phone = "9082543992", 
  text = "Hi RoasBodhi" 
} = Astro.props;

const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(text)}`;
---

<!-- Fixed position WhatsApp Button (above mobile CTA on mobile, standard bottom-8 on desktop) -->
<a 
  href={whatsappUrl} 
  target="_blank" 
  rel="noopener noreferrer" 
  class="fixed right-6 z-50 flex items-center justify-center w-14 h-14 bg-emerald-600 text-white rounded-full shadow-[0_8px_25px_rgba(37,211,102,0.40)] hover:scale-110 active:scale-95 transition-all duration-300 group bottom-20 md:bottom-8"
  aria-label="Chat with us on WhatsApp"
>
  <!-- Animated pulse outer ring -->
  <span class="absolute inset-0 rounded-full bg-emerald-500/35 animate-ping"></span>
  
  <MessageCircle class="w-7 h-7 relative z-10 fill-white" />
  
  <!-- Tooltip (desktop only) -->
  <span class="absolute right-full mr-3 px-3 py-1.5 rounded-lg bg-neutral-dark text-white text-xs font-display font-semibold whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none shadow-md">
    Chat on WhatsApp
  </span>
</a>
