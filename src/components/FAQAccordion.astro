---
interface Props {
  faqs: {
    question: string;
    answer: string;
  }[];
}

const { faqs } = Astro.props;

// Compile FAQ Schema JSON-LD automatically
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<[^>]*>/g, '') // Strip HTML tags for clean schema text
    }
  }))
};
---

<div class="flex flex-col gap-4 max-w-4xl mx-auto w-full">

  {faqs.map((faq) => (
    <details class="group bg-white border border-neutral-mist rounded-2xl p-6 shadow-sm hover:border-primary-saffron/30 hover:shadow-card-default transition-all duration-300 [&_summary::-webkit-details-marker]:hidden select-none">
      <summary class="flex items-center justify-between cursor-pointer focus:outline-none list-none">
        <h4 class="font-display font-bold text-neutral-dark text-base sm:text-lg leading-snug group-hover:text-primary-saffron transition-colors pr-4">
          {faq.question}
        </h4>
        <div class="w-8 h-8 rounded-full bg-neutral-ghost flex items-center justify-center flex-shrink-0 text-neutral-charcoal group-hover:bg-primary-saffron/10 group-hover:text-primary-saffron transition-colors">
          <!-- Chevron Arrow rotating 180deg when open -->
          <svg class="w-4 h-4 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </summary>
      <div class="mt-4 pt-4 border-t border-neutral-mist/50">
        <p class="font-body text-sm text-neutral-charcoal/80 leading-relaxed" set:html={faq.answer}>
        </p>
      </div>
    </details>
  ))}
</div>
