---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyWhatsApp from '../components/StickyWhatsApp.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import { ChevronRight, ArrowUp } from 'lucide-astro';

interface Props {
  title: string;
  description: string;
  breadcrumbs?: { label: string; link: string }[];
  ogImage?: string;
  noIndex?: boolean;
  schema?: object;
}

const { title, description, breadcrumbs, ogImage, noIndex, schema } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} noIndex={noIndex} schema={schema}>
  
  <!-- Navigation Header -->
  <Header />

  <!-- Page Transition & Content Wrapper -->
  <div class="flex flex-col min-h-screen animate-fade-up">
    
    <!-- Main Content Area -->
    <main id="main-content" class="flex-grow pt-24 pb-16">
      
      <!-- Breadcrumb Navigation if provided -->
      {breadcrumbs && breadcrumbs.length > 0 && (
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 mb-6 select-none" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-xs font-body font-semibold text-neutral-stone">
            <li>
              <a href="/" class="hover:text-primary-saffron transition-colors">Home</a>
            </li>
            {breadcrumbs.map((crumb, index) => (
              <li class="flex items-center gap-2">
                <ChevronRight class="w-3 h-3 text-neutral-mist" />
                {index === breadcrumbs.length - 1 ? (
                  <span class="text-neutral-charcoal font-bold" aria-current="page">
                    {crumb.label}
                  </span>
                ) : (
                  <a href={crumb.link} class="hover:text-primary-saffron transition-colors">
                    {crumb.label}
                  </a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )}

      <!-- Dynamic Page slot -->
      <slot />

    </main>

    <!-- Footer Component -->
    <Footer />

  </div>

  <!-- Persistent Dynamic Floating Widgets -->
  <StickyWhatsApp />
  <StickyMobileCTA />

  <!-- Scroll To Top Button (Triggered via scroll distance) -->
  <button 
    id="scroll-to-top" 
    class="fixed bottom-24 right-6 z-40 w-11 h-11 bg-white border border-neutral-mist hover:border-primary-saffron text-neutral-charcoal hover:text-primary-saffron rounded-full shadow-md flex items-center justify-center translate-y-12 opacity-0 pointer-events-none transition-all duration-300 group"
    aria-label="Scroll back to top of page"
  >
    <ArrowUp class="w-5 h-5 transition-transform duration-200 group-hover:-translate-y-0.5" />
  </button>

</BaseLayout>

<script>
  // Script to handle Scroll-to-top appearance and trigger actions
  const scrollTopBtn = document.getElementById('scroll-to-top');

  if (scrollTopBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        // Show button
        scrollTopBtn.classList.remove('translate-y-12', 'opacity-0', 'pointer-events-none');
        scrollTopBtn.classList.add('translate-y-0', 'opacity-100');
      } else {
        // Hide button
        scrollTopBtn.classList.remove('translate-y-0', 'opacity-100');
        scrollTopBtn.classList.add('translate-y-12', 'opacity-0', 'pointer-events-none');
      }
    });

    scrollTopBtn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }
</script>
